# secrets (injected into container) e config local
# legacy paths (claudinho → leech)
claudinho/.env
claudinho/claudio-cli/.claudio
leech/cli/.env
leech/cli/leech
stow/.local/bin/leech

# leech docker environment files — NEVER commit real secrets to git
leech/dockerized/**/env/*.env
!leech/dockerized/**/env/*.env.example

# agent
tmp/
result/
result/**
result/*

# nixos
.direnv

# misc
.opencode/
.vscode/
*.pem
nano.*.save
.claude/scheduled_tasks.lock

# lock configuration.nix file
setup.nix

# dont care to lock, me is maverick
flake.lock
boot.nix

# vscode/cursor: ignore everything, then re-include only user configs
stow/.config/Code/*
!stow/.config/Code/User/
stow/.config/Code/User/*
!stow/.config/Code/User/settings.json
!stow/.config/Code/User/keybindings.json
!stow/.config/Code/User/snippets/

stow/.config/Cursor/*
!stow/.config/Cursor/User/
stow/.config/Cursor/User/*
!stow/.config/Cursor/User/settings.json
!stow/.config/Cursor/User/keybindings.json
!stow/.config/Cursor/User/snippets/

# claude: worktrees and auto-generated/ephemeral
.claude/worktrees/
stow/.claude/plugins/
stow/.claude/skills/skill-evaluations/

# ephemeral
.ephemeral/

# execution logs	
logs/

# vault: bind mount do Obsidian — sync exclusivo pelo Obsidian Sync, git não toca
vault/

# workspace: work projects mounted from outside (have their own git)
projetos/claudio/

workbench/
workbench/**
workbench/*

.claude/

.env

.weblive
# Cursor: regras versionadas; espelho do session-start é gerado localmente
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.cursor/session-boot.md
