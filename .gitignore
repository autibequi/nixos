# ── Secrets / config local (nunca commitar) ──────────────────────────
*.pem
.env
*/self/shadow/memory/

# Config gerada por máquina (hardware-specific, não versionada)
setup.nix
boot.nix

# ── Nix ───────────────────────────────────────────────────────────────
.direnv
result
# flake.lock não versionado — "me is maverick"
flake.lock

# ── Editores ──────────────────────────────────────────────────────────
.opencode/
.vscode/

# VSCode: ignora tudo, re-inclui só configs do usuário
stow/.config/Code/*
!stow/.config/Code/User/
stow/.config/Code/User/*
!stow/.config/Code/User/settings.json
!stow/.config/Code/User/keybindings.json
!stow/.config/Code/User/snippets/

# Cursor: idem + regras versionadas; espelho do session-start é gerado localmente
stow/.config/Cursor/*
!stow/.config/Cursor/User/
stow/.config/Cursor/User/*
!stow/.config/Cursor/User/settings.json
!stow/.config/Cursor/User/keybindings.json
!stow/.config/Cursor/User/snippets/
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.cursor/session-boot.md

# ── Claude (efêmeros, worktrees, plugins) ─────────────────────────────
.claude/
stow/.claude/plugins/
stow/.claude/skills/skill-evaluations/

# ── Efêmeros / runtime ────────────────────────────────────────────────
.ephemeral/
tmp/
logs/
.weblive
*.pyc

# CLIs locais (hypr-*, gpu-profile gerado, etc) — não versionados
stow/.local/bin
.local/bin

# vault: bind mount do Obsidian — sync exclusivo pelo Obsidian Sync, git não toca
vault/
