# agent
tmp/
result/
result/**
result/*

# nixos
.direnv

# misc
.opencode/
.vscode/
*.pem
nano.*.save
.claude/scheduled_tasks.lock

# lock configuration.nix file
setup.nix

# dont care to lock, me is maverick
flake.lock
boot.nix

# vscode/cursor: ignore everything, then re-include only user configs
stow/.config/Code/*
!stow/.config/Code/User/
stow/.config/Code/User/*
!stow/.config/Code/User/settings.json
!stow/.config/Code/User/keybindings.json
!stow/.config/Code/User/snippets/

stow/.config/Cursor/*
!stow/.config/Cursor/User/
stow/.config/Cursor/User/*
!stow/.config/Cursor/User/settings.json
!stow/.config/Cursor/User/keybindings.json
!stow/.config/Cursor/User/snippets/

# claude: worktrees and auto-generated/ephemeral
.claude/worktrees/
stow/.claude/plugins/
stow/.claude/skills/skill-evaluations/

# ephemeral
.ephemeral/

# execution logs
logs/

# vault: mount point for Obsidian (docker-compose bind mount)
vault/
# un-ignore agent area inside vault (tasks + reports are versioned)
!vault/_agent/
!vault/_agent/**

# task lifecycle (só CLAUDE.md das tasks é versionado)
vault/_agent/tasks/.runner.lock
vault/_agent/tasks/running/
vault/_agent/tasks/done/
vault/_agent/tasks/failed/
vault/_agent/tasks/**/memoria.md
vault/_agent/tasks/**/.lock
vault/_agent/tasks/**/contexto.md
vault/_agent/tasks/.obsidian/

# task nested duplicates (auto-gerados por bug de tasks que criam subpasta com mesmo nome)
vault/_agent/tasks/*/*/avaliar-m5/
vault/_agent/tasks/*/*/review-cached-ldi-toc/
vault/_agent/tasks/*/*/melhorar-automacoes/
vault/_agent/tasks/*/*/parceiro/

# agent reports (generated, not versioned)
vault/_agent/reports/

# workspace: work projects mounted from outside (have their own git)
projetos/claudio/
