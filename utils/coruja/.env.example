# .env.example — Estratégia Dev Stack
#
# Copiar para .env e preencher os valores marcados com "→ SECRET".
# Nunca commitar .env (está no .gitignore).
#
# Secrets sensíveis (DB_PASSWORD, tokens) devem ir em .env.secrets (chmod 600).
# Incluir no .env: set -a && source .env.secrets && set +a

# ─────────────────────────────────────────────────────────────────────────────
# Caminhos dos apps (OBRIGATÓRIO — ajustar para o seu host)
# ─────────────────────────────────────────────────────────────────────────────

# Diretório do app monolito no host (bind-mount → /go/apps/monolito no container)
# O build context usa APP_DIR_MONOLITO/.. (apps/) para que go.work resolve SDKs irmãos.
APP_DIR_MONOLITO=/home/pedro/projects/estrategia/coruja/apps/monolito

# Diretório do bo-container no host (bind-mount → /app no container)
APP_DIR_BO=/home/pedro/projects/estrategia/coruja/apps/bo-container

# Diretório do front-student no host (bind-mount → /app no container)
APP_DIR_FRONT=/home/pedro/projects/estrategia/coruja/apps/front-student

# Clone do pdf-kit no host (repo próprio estrategiahq/pdf-kit; build context do consumer)
APP_DIR_PDFKIT=/home/pedro/projects/estrategia/pdf-kit

# ─────────────────────────────────────────────────────────────────────────────
# Certificados TLS
# ─────────────────────────────────────────────────────────────────────────────

# Diretório com fullchain.pem + privkey.pem gerados pelo scripts/gen-cert.sh
# Padrão: ./certs (relativo ao docker-compose.yml)
CERT_DIR=./certs

# ─────────────────────────────────────────────────────────────────────────────
# App / Ambiente
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=local
VERTICAL=carreiras-juridicas

# Script npm que o front-student usa: local | sandbox | devbox
# Determina qual bloco do package.json é executado (ex: "local:carreiras-juridicas")
NPM_SCRIPT_ENV=local

# BFF URL do front-student
# local  → https://api.local.estrategia-sandbox.com.br/  (monolito local)
# sandbox → https://api.estrategia-sandbox.com.br/
# prod   → https://api.estrategia.com/
BFF_URL=https://api.local.estrategia-sandbox.com.br/

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

DB_USER=estrategia
DB_NAME=estrategia

# → mover para .env.secrets (não commitar)
DB_PASSWORD=estrategia

# ─────────────────────────────────────────────────────────────────────────────
# AWS (LocalStack — valores fake para dev local)
# ─────────────────────────────────────────────────────────────────────────────

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-2
SERVICES=sqs,s3
DEFAULT_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# Debug (Delve)
# ─────────────────────────────────────────────────────────────────────────────

# Setar para 1 para ativar o Delve no monolito (porta 2345)
PLUG_DEBUG_APP=0

# Setar para 1 para ativar o Delve no worker (porta 2346)
PLUG_DEBUG_WORKER=0

# ─────────────────────────────────────────────────────────────────────────────
# Dockerfiles alternativos (opcional — padrão usa o Dockerfile do próprio app)
# ─────────────────────────────────────────────────────────────────────────────

# Caminho do Dockerfile do monolito relativo ao context (apps/)
# Padrão: ./monolito/Dockerfile  (Dockerfile que vem no repo plug)
# MONOLITO_DOCKERFILE=./monolito/Dockerfile

# Dockerfile do bo-container relativo ao APP_DIR_BO
# BO_DOCKERFILE=./Dockerfile

# Dockerfile do front-student relativo ao APP_DIR_FRONT
# FRONT_DOCKERFILE=./Dockerfile

# ─────────────────────────────────────────────────────────────────────────────
# BO Container — ambiente vite
# ─────────────────────────────────────────────────────────────────────────────

# Bloco do .env-cmdrc.js a usar quando o BO é servido via node -e (modo avançado)
BO_ENV=sandbox

# ─────────────────────────────────────────────────────────────────────────────
# Secrets — mover para .env.secrets (chmod 600, não commitar)
# ─────────────────────────────────────────────────────────────────────────────
# DB_PASSWORD=...               ← senha real do postgres
# GITHUB_NPM_TOKEN=...          ← token para npm.pkg.github.com (@estrategiahq/*)
#                                  colocar também em ~/.npmrc:
#                                  //npm.pkg.github.com/:_authToken=<TOKEN>
