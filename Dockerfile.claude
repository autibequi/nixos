FROM nixos/nix:latest

# Enable flakes and configure Nix
RUN mkdir -p /etc/nix && \
    echo "experimental-features = nix-command flakes" >> /etc/nix/nix.conf

# Copy declarative package definition
COPY claudeOS/ /tmp/claudeOS/

# Build declarative env (sem nix-env -i pra evitar conflito com perfil base)
RUN nix-build /tmp/claudeOS/ -A env -o /nix/claudeos-env && \
    rm -rf /tmp/claudeOS

# Install Claude Code via npm
ENV NPM_CONFIG_PREFIX=/usr/local
ENV PATH="/usr/local/bin:/nix/claudeos-env/bin:/root/.nix-profile/bin:${PATH}"
RUN npm install -g @anthropic-ai/claude-code

# Create non-root user with required groups
RUN echo "claude:x:1000:1000::/home/claude:/bin/bash" >> /etc/passwd && \
    echo "claude:x:1000:" >> /etc/group && \
    echo "systemd-journal:x:190:claude" >> /etc/group && \
    echo "docker:x:999:claude" >> /etc/group && \
    mkdir -p /home/claude/.claude && \
    chown -R 1000:1000 /home/claude

# Create /bin/bash symlink
RUN ln -sf /nix/claudeos-env/bin/bash /bin/bash

# Give claude ownership of nix writable dirs (store é read-only, não precisa chown)
RUN sed -i '/^build-users-group/d' /etc/nix/nix.conf && \
    chown -R 1000:1000 /nix/var /nix/claudeos-env && \
    chmod 1775 /nix/store

USER claude
ENV PATH="/usr/local/bin:/nix/claudeos-env/bin:${PATH}"
ENV HOME=/home/claude

WORKDIR /workspace
