FROM nixos/nix:latest

# Enable flakes and nix-command
RUN mkdir -p /etc/nix && \
    echo "experimental-features = nix-command flakes" >> /etc/nix/nix.conf

# Install common tools Claude Code might need
RUN nix profile install \
    nixpkgs#bash \
    nixpkgs#coreutils \
    nixpkgs#curl \
    nixpkgs#git \
    nixpkgs#jq \
    nixpkgs#yt-dlp \
    nixpkgs#ffmpeg \
    nixpkgs#python3 \
    nixpkgs#ripgrep \
    nixpkgs#findutils \
    nixpkgs#gnused \
    nixpkgs#gnugrep \
    nixpkgs#gawk \
    nixpkgs#wget

WORKDIR /workspace

ENTRYPOINT ["/bin/bash"]
