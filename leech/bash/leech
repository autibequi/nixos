    "claude usage") leech_claude_usage_command ;;
    "claude token") leech_claude_token_command ;;
    "build") leech_build_command ;;
    "down") leech_down_command ;;
    "shutdown") leech_shutdown_command ;;
    "clean") leech_clean_command ;;
    "update") leech_update_command ;;
    "set") leech_set_command ;;
    "runner") leech_runner_command ;;
    "hooks") leech_hooks_command ;;
    "tick") leech_tick_command ;;
    "tasker") leech_tasker_command ;;
    "run") leech_run_command ;;
    "agents") leech_agents_command ;;
    "agents list") leech_agents_list_command ;;
    "agents phone") leech_agents_phone_command ;;
    "agents status") leech_agents_status_command ;;
    "tasks") leech_tasks_command ;;
    "tasks log") leech_tasks_log_command ;;
    "tasks status") leech_tasks_status_command ;;
    "status") leech_status_command ;;
    "stow") leech_stow_command ;;
    "os") leech_os_command ;;
    "os switch") leech_os_switch_command ;;
    "os test") leech_os_test_command ;;
    "os boot") leech_os_boot_command ;;
    "os build") leech_os_build_command ;;
    "os update") leech_os_update_command ;;
    "leech") leech_leech_command ;;
    "inbox") leech_inbox_command ;;
    "outbox") leech_outbox_command ;;
    "help") leech_help_command ;;
    "man") leech_man_command ;;
    "relay") leech_relay_command ;;
    "caffeine") leech_caffeine_command ;;
    "uninstall") leech_uninstall_command ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  initialize
  run "$@"
fi
