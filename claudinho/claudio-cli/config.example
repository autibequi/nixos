# Configuração do claudio — copie para ~/.claudio e ajuste (chmod 600 ~/.claudio)
# Este arquivo é sourceado pelo CLI; use sintaxe shell KEY=value.
# Nunca commite ~/.claudio (contém tokens).

# ── Engine e modelo (--engine e --model na linha de comando sobrescrevem)
# opencode = OpenCode TUI | claude = Claude Code | cursor = Cursor
engine=claude
# haiku | opus (vazio = sonnet)
# model=sonnet

# ── Tokens (injetados no container; use sempre menor escopo possível)
# GitHub: Fine-grained PAT com Pull requests / Contents / Issues read-only
GH_TOKEN=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# ── Opcionais
# Caminho do vault Obsidian (default: $HOME/.ovault)
# OBSIDIAN_PATH=$HOME/.ovault

# Raiz do repo NixOS (default: $HOME/nixos)
# CLAUDIO_NIXOS_DIR=$HOME/nixos
