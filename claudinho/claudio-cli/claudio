# :command.parse_requirements
parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        claudio_usage
        exit
        ;;

      # :flag.case
      --engine)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--engine']="$2"
          shift
          shift
        else
          printf "%s\n" "--engine requires an argument: --engine ENGINE" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --haiku)

        # :flag.case_no_arg
        args['--haiku']=1
        shift
        ;;

      # :flag.case
      --opus)

        # :flag.case_no_arg
        args['--opus']=1
        shift
        ;;

      # :flag.case
      --instance)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--instance']="$2"
          shift
          shift
        else
          printf "%s\n" "--instance requires an argument: --instance ID" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --rw)

        # :flag.case_no_arg
        args['--rw']=1
        shift
        ;;

      # :flag.case
      --ro)

        # :flag.case_no_arg
        args['--ro']=1
        shift
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.environment_variables_filter

  env_var_names+=("CLAUDIO_NIXOS_DIR")
  env_var_names+=("OBSIDIAN_PATH")

  # :command.command_filter
  action=${1:-}

  case $action in

    run | r | open | opencode | code)
      action="run"
      shift
      claudio_run_parse_requirements "$@"
      shift $#
      ;;

    shell | sh)
      action="shell"
      shift
      claudio_shell_parse_requirements "$@"
      shift $#
      ;;

    resume)
      action="resume"
      shift
      claudio_resume_parse_requirements "$@"
      shift $#
      ;;

    continue | cont)
      action="continue"
      shift
      claudio_continue_parse_requirements "$@"
      shift $#
      ;;

    start)
      action="start"
      shift
      claudio_start_parse_requirements "$@"
      shift $#
      ;;

    openclaw)
