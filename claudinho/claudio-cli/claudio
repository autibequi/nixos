  declare -g long_usage=''
  declare -g -A args=()
  declare -g -A deps=()
  declare -g -a env_var_names=()
  declare -g -a input=()

  normalize_input "$@"
  parse_requirements "${input[@]}"

  case "$action" in
    "run") claudio_run_command ;;
    "shell") claudio_shell_command ;;
    "resume") claudio_resume_command ;;
    "continue") claudio_continue_command ;;
    "start") claudio_start_command ;;
    "openclaw") claudio_openclaw_command ;;
    "build") claudio_build_command ;;
    "down") claudio_down_command ;;
    "destroy") claudio_destroy_command ;;
