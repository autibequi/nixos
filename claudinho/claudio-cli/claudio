# :command.parse_requirements
parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        claudio_usage
        exit
        ;;

      # :flag.case
      --engine)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--engine']="$2"
          shift
          shift
        else
          printf "%s\n" "--engine requires an argument: --engine ENGINE" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --model)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--model']="$2"
          shift
          shift
        else
          printf "%s\n" "--model requires an argument: --model MODEL" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --instance)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--instance']="$2"
          shift
          shift
        else
          printf "%s\n" "--instance requires an argument: --instance ID" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --rw)

        # :flag.case_no_arg
        args['--rw']=1
        shift
        ;;

      # :flag.case
      --ro)

        # :flag.case_no_arg
        args['--ro']=1
        shift
        ;;

      # :flag.case
      --danger)

        # :flag.case_no_arg
        args['--danger']=1
        shift
        ;;

      # :flag.case
      --init-md)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--init-md']="$2"
          shift
          shift
        else
          printf "%s\n" "--init-md requires an argument: --init-md FILE" >&2
          exit 1
        fi
        ;;

      --resume=*)
        args['--resume']="${key#--resume=}"
        shift
        ;;

      --resume)
        if [[ -n ${2+x} && ${2} != -* ]]; then
          args['--resume']="$2"
          shift
          shift
        else
          args['--resume']=1
          shift
        fi
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.environment_variables_filter

  env_var_names+=("CLAUDIO_NIXOS_DIR")
  env_var_names+=("OBSIDIAN_PATH")

  # :command.command_filter
  action=${1:-}

  case $action in

    run | r | open | opencode | code)
      action="run"
      shift
      claudio_run_parse_requirements "$@"
      shift $#
      ;;

    shell | sh)
      action="shell"
      shift
      claudio_shell_parse_requirements "$@"
      shift $#
      ;;

    resume)
      action="resume"
      shift
      claudio_resume_parse_requirements "$@"
      shift $#
      ;;

    continue | cont)
      action="continue"
      shift
      claudio_continue_parse_requirements "$@"
      shift $#
      ;;

    start)
      action="start"
      shift
      claudio_start_parse_requirements "$@"
      shift $#
      ;;

    openclaw)
      action="openclaw"
      shift
      claudio_openclaw_parse_requirements "$@"
      shift $#
      ;;

    build)
      action="build"
      shift
      claudio_build_parse_requirements "$@"
      shift $#
      ;;

    down)
      action="down"
      shift
      claudio_down_parse_requirements "$@"
      shift $#
      ;;

    destroy)
      action="destroy"
      shift
      claudio_destroy_parse_requirements "$@"
      shift $#
      ;;

    update | install)
      action="update"
      shift
      claudio_update_parse_requirements "$@"
      shift $#
      ;;

    init)
      action="init"
      shift
      claudio_init_parse_requirements "$@"
      shift $#
      ;;

    worker | w)
      action="worker"
      shift
      claudio_worker_parse_requirements "$@"
      shift $#
      ;;

    worker-run-fast | wrf)
      action="worker-run-fast"
      shift
      claudio_worker_run_fast_parse_requirements "$@"
      shift $#
      ;;

    worker-auto)
      action="worker-auto"
      shift
      claudio_worker_auto_parse_requirements "$@"
      shift $#
      ;;

    worker-clau)
      action="worker-clau"
      shift
      claudio_worker_clau_parse_requirements "$@"
      shift $#
      ;;

    worker-stop)
      action="worker-stop"
      shift
      claudio_worker_stop_parse_requirements "$@"
      shift $#
      ;;

    worker-stop-all)
      action="worker-stop-all"
      shift
      claudio_worker_stop_all_parse_requirements "$@"
      shift $#
      ;;

    scheduler | sched)
      action="scheduler"
      shift
      claudio_scheduler_parse_requirements "$@"
      shift $#
      ;;

    reset)
      action="reset"
      shift
      claudio_reset_parse_requirements "$@"
      shift $#
      ;;

    status)
      action="status"
      shift
      claudio_status_parse_requirements "$@"
      shift $#
      ;;

    new)
      action="new"
      shift
      claudio_new_parse_requirements "$@"
      shift $#
      ;;

    logs)
      action="logs"
      shift
      claudio_logs_parse_requirements "$@"
      shift $#
      ;;

    logs-list)
      action="logs-list"
      shift
      claudio_logs_list_parse_requirements "$@"
      shift $#
      ;;

    usage-api)
      action="usage-api"
      shift
      claudio_usage_api_parse_requirements "$@"
      shift $#
      ;;

    service-logs)
      action="service-logs"
      shift
      claudio_service_logs_parse_requirements "$@"
      shift $#
      ;;

    ask)
      action="ask"
      shift
      claudio_ask_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    *)
      action="run"
      claudio_run_parse_requirements "$@"
      shift $#
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

  # :command.default_assignments
  [[ -n ${args['--init-md']:-} ]] || args['--init-md']="contexto.md"

}

