    "init") claudio_init_command ;;
    "worker") claudio_worker_command ;;
    "worker-run-fast") claudio_worker_run_fast_command ;;
    "worker-auto") claudio_worker_auto_command ;;
    "worker-clau") claudio_worker_clau_command ;;
    "worker-stop") claudio_worker_stop_command ;;
    "worker-stop-all") claudio_worker_stop_all_command ;;
    "scheduler") claudio_scheduler_command ;;
    "reset") claudio_reset_command ;;
    "status") claudio_status_command ;;
    "new") claudio_new_command ;;
    "logs") claudio_logs_command ;;
    "logs-list") claudio_logs_list_command ;;
    "usage-api") claudio_usage_api_command ;;
    "service-logs") claudio_service_logs_command ;;
    "ask") claudio_ask_command ;;
  esac
}

