# Monolito — sandbox environment
APP_ENV=sandbox
APP_PORT=4004

# Database
DB_HOST=zion-dk-monolito-postgres
DB_PORT=5432
DB_USER=estrategia
DB_PASSWORD=estrategia
DB_NAME=estrategia
DB_SSLMODE=disable

# Redis
REDIS_HOST=zion-dk-monolito-redis
REDIS_PORT=6379

# AWS / LocalStack
AWS_ENDPOINT=http://zion-dk-monolito-localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Logging
LOG_LEVEL=debug
