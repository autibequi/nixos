zion_outbox_command() {

  # src/commands/outbox.sh
  # Lista o outbox
  local obsidian="${OBSIDIAN_PATH:-$HOME/.ovault/Work}"
  local outbox_dir="$obsidian/outbox"

  # Fallback path
