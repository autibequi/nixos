{
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(/)",
      "Write(/)",
      "Edit(/)",
      "Glob(/)",
      "Grep(/)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__*(*)",
      "ToolSearch(*)"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["nixos"],
  "hooks": {
    "SessionStart": [{"matcher": "startup","hooks": [{"type": "command","command": "~/.claude/hooks/session-start.sh"}]}],
    "PreToolUse": [{"matcher": ".*","hooks": [{"type": "command","command": "~/.claude/hooks/pre-tool-use.sh"}]}],
    "PostToolUse": [{"matcher": ".*","hooks": [{"type": "command","command": "~/.claude/hooks/post-tool-use.sh"}]}]
  },
  "statusLine": {"type": "command","command": "~/.claude/scripts/statusline.sh"}
}
