# ┌─────────────────────────────────────────────────────────────┐
# │  Overrides locais para o compose (opcional).               │
# │  Chaves (GH_TOKEN, ANTHROPIC_API_KEY, CURSOR_API_KEY) e     │
# │  engine padrão ficam em ~/.claudio — copie de config.example.│
# │  Este .env NÃO é commitado (.gitignore).                   │
# └─────────────────────────────────────────────────────────────┘

# ── Paths (override; senão usa ~/.claudio e env) ─────────────
# OBSIDIAN_PATH=$HOME/.ovault

# ── Engine cursor (opcional) ─────────────────────────────────
# CURSOR_API_KEY=...   # para agent no container; ou use agent login no host (mount ~/.cursor)
