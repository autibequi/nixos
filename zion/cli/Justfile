# Zion CLI — dev tooling
# Uso: just <recipe>
# Requer: just, bashly, bash

set shell := ["bash", "-c"]

nixos_dir := env_var_or_default("ZION_NIXOS_DIR", env_var("HOME") + "/nixos")
cli_dir    := justfile_directory()
bin_dest   := nixos_dir + "/stow/.local/bin/zion"
hooks_dir  := nixos_dir + "/zion/hooks/claude-code"

# Lista receitas disponíveis
default:
    @just --list

# ── Build ─────────────────────────────────────────────────────────────────

# Regenera o binário zion (bashly generate)
gen:
    LANG=en_US.UTF-8 RUBYOPT="-E utf-8" bashly generate

# Regenera + instala symlink + atualiza bootstrap (= zion update)
install: gen
    mkdir -p "$(dirname "{{bin_dest}}")"
    @if [[ ! -L "{{bin_dest}}" ]]; then \
        ln -sf "{{cli_dir}}/zion" "{{bin_dest}}"; \
        echo "[install] symlink criado: {{bin_dest}}"; \
    else \
        echo "[install] regenerado (symlink ja existe)"; \
    fi
    @if [[ -f "{{nixos_dir}}/zion/scripts/bootstrap-dashboard.sh" ]]; then \
        install -m 755 "{{nixos_dir}}/zion/scripts/bootstrap-dashboard.sh" "{{nixos_dir}}/scripts/bootstrap.sh"; \
        echo "[install] bootstrap.sh atualizado"; \
    fi

# ── Hooks / Debug ─────────────────────────────────────────────────────────

# Simula o boot (session-start) e mostra o que seria injetado
dry hook="session-start" *overrides="":
    @echo "--- DRY RUN: {{hook}} {{overrides}} ---"
    @if [[ -n "{{overrides}}" ]]; then \
        for kv in {{overrides}}; do export "${kv^^}"; done; \
    fi
    @echo '{"session_id":"dry-run","prompt":"startup"}' | bash "{{hooks_dir}}/{{hook}}.sh"

# Simula boot em modo zion_edit (com ZION_EDIT=1)
dry-edit:
    @just dry session-start ZION_EDIT=1

# Simula boot em modo debug
dry-debug:
    @just dry session-start DEBUG=1

# Simula boot headless
dry-headless:
    @just dry session-start HEADLESS=1

# Lista hooks disponíveis
hooks:
    @ls "{{hooks_dir}}"/*.sh | xargs -I{} basename {} .sh

# ── Watch ─────────────────────────────────────────────────────────────────

# Regenera o binário ao salvar qualquer arquivo em src/
watch:
    @command -v watchexec >/dev/null 2>&1 || { echo "instale watchexec: nix-shell -p watchexec"; exit 1; }
    watchexec -e yml,sh -w src/ -- just gen

# ── Lint / Check ──────────────────────────────────────────────────────────

# Valida sintaxe de todos os .sh em src/commands/
lint:
    @errors=0; \
    for f in src/commands/*.sh src/lib/*.sh; do \
        bash -n "$f" 2>&1 && true || { echo "ERRO: $f"; errors=$((errors+1)); }; \
    done; \
    [[ $errors -eq 0 ]] && echo "OK — todos os scripts validos" || exit 1

# Valida o bashly.yml (dry-run do generate)
check:
    LANG=en_US.UTF-8 RUBYOPT="-E utf-8" bashly validate
