# syntax=docker/dockerfile:1
# Stage 0: install Cursor CLI on Debian (FHS + glibc/libstdc++ for node binary)
FROM debian:bookworm-slim AS cursor-cli
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates && \
    curl -fsSL https://cursor.com/install | bash && \
    rm -rf /var/lib/apt/lists/*

FROM nixos/nix:latest

# Enable flakes and nix-command
RUN mkdir -p /etc/nix && \
    echo "experimental-features = nix-command flakes" >> /etc/nix/nix.conf

# Install common tools + Claude Code via Nix (evita instalador oficial que exige glibc FHS)
# --mount=type=cache: reutiliza tarballs baixados entre rebuilds (não re-baixa do cache.nixos.org)
RUN --mount=type=cache,target=/root/.cache/nix \
    nix profile install \
    nixpkgs#jq \
    nixpkgs#yt-dlp \
    nixpkgs#python3 \
    nixpkgs#wl-clipboard \
    nixpkgs#sox \
    nixpkgs#util-linux \
    nixpkgs#systemdMinimal \
    nixpkgs#gh \
    nixpkgs#gawk \
    nixpkgs#gnused \
    nixpkgs#espeak-ng \
    nixpkgs#coreutils \
    nixpkgs#gosu \
    nixpkgs#opencode \
    nixpkgs#docker-client && \
    nix profile install github:sadjow/claude-code-nix

# Create non-root user and copy profile (claude binary fica em .nix-profile/bin)
RUN echo "claude:x:1000:1000::/home/claude:/bin/bash" >> /etc/passwd && \
    echo "claude:x:1000:" >> /etc/group && \
    echo "systemd-journal:x:190:claude" >> /etc/group && \
    mkdir -p /home/claude/.claude /home/claude/.local /home/claude/.config/cursor && \
    cp -r /root/.nix-profile /home/claude/.nix-profile && \
    chown -R 1000:1000 /home/claude && \
    ln -sf /root/.nix-profile/bin/bash /bin/bash

# Cursor CLI: copy from Debian stage + FHS libs so bundled node runs
RUN mkdir -p /home/claude/.local/bin /home/claude/.local/share /lib64 /lib/x86_64-linux-gnu
COPY --from=cursor-cli /root/.local/bin/ /home/claude/.local/bin/
COPY --from=cursor-cli /root/.local/share/ /home/claude/.local/share/
# Cursor node binary expects Debian FHS: loader in /lib64, other libs in /lib/x86_64-linux-gnu
COPY --from=cursor-cli /lib/x86_64-linux-gnu/ld-linux-x86-64.so.2 /lib64/
COPY --from=cursor-cli /lib/x86_64-linux-gnu/libc.so.6 /lib/x86_64-linux-gnu/libdl.so.2 /lib/x86_64-linux-gnu/libpthread.so.0 /lib/x86_64-linux-gnu/libm.so.6 /lib/x86_64-linux-gnu/
COPY --from=cursor-cli /usr/lib/x86_64-linux-gnu/libstdc++.so.6 /usr/lib/x86_64-linux-gnu/libgcc_s.so.1 /lib/x86_64-linux-gnu/
RUN CURSOR_VER="$(ls /home/claude/.local/share/cursor-agent/versions)" && \
    rm -f /home/claude/.local/bin/agent /home/claude/.local/bin/cursor-agent && \
    ln -s /home/claude/.local/share/cursor-agent/versions/"$CURSOR_VER"/cursor-agent /home/claude/.local/bin/agent && \
    ln -s /home/claude/.local/share/cursor-agent/versions/"$CURSOR_VER"/cursor-agent /home/claude/.local/bin/cursor-agent && \
    chown -R 1000:1000 /home/claude/.local

# MCP Grafana server (static Go binary — read-only dashboards/Loki queries)
RUN curl -fsSL "https://github.com/grafana/mcp-grafana/releases/latest/download/mcp-grafana_Linux_x86_64.tar.gz" \
    | tar xz -C /home/claude/.local/bin/ mcp-grafana && \
    chown 1000:1000 /home/claude/.local/bin/mcp-grafana

# Workspace owned by claude (evita dirs criados como root)
RUN mkdir -p /workspace && chown claude:claude /workspace

# Entrypoint: inicia nix-daemon como root, cria dirs essenciais como claude, depois delega via gosu
RUN printf '#!/bin/bash\n\
nix-daemon &\n\
sleep 1\n\
# Garantir dirs essenciais com dono correto antes de trocar usuario\n\
mkdir -p /workspace/.ephemeral/locks /workspace/.ephemeral/notes /workspace/.ephemeral/scratch /tmp/zion-locks\n\
chown -R claude:claude /workspace/.ephemeral /tmp/zion-locks 2>/dev/null || true\n\
chown -R claude:claude /workspace/obsidian/agents/cron 2>/dev/null || true\n\
exec gosu claude "$@"\n' > /entrypoint.sh && \
    chmod +x /entrypoint.sh

# Container roda como root por default para que /entrypoint.sh possa iniciar nix-daemon.
# gosu no entrypoint cuida da troca para claude. docker exec usa -u claude explicitamente.
# PATH: Cursor CLI (agent) + .nix-profile (claude e gosu instalados aqui)
ENV PATH="/home/claude/.local/bin:/home/claude/.nix-profile/bin:/root/.nix-profile/bin:/usr/bin:/bin:${PATH}"
ENV HOME=/home/claude

ENTRYPOINT ["/entrypoint.sh"]
WORKDIR /workspace
