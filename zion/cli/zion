# :command.parse_requirements
parse_requirements() {
  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        zion_usage
        exit
        ;;

      # :flag.case
      --engine)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--engine']="$2"
          shift
          shift
        else
          printf "%s\n" "--engine requires an argument: --engine ENGINE" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --model)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--model']="$2"
          shift
          shift
        else
          printf "%s\n" "--model requires an argument: --model MODEL" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --instance)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--instance']="$2"
          shift
          shift
        else
          printf "%s\n" "--instance requires an argument: --instance ID" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --rw)

        # :flag.case_no_arg
        args['--rw']=1
        shift
        ;;

      # :flag.case
      --ro)

        # :flag.case_no_arg
        args['--ro']=1
        shift
        ;;

      # :flag.case
      --danger)

        # :flag.case_no_arg
        args['--danger']=1
        shift
        ;;

      # :flag.case
      --init-md)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--init-md']="$2"
          shift
          shift
        else
          printf "%s\n" "--init-md requires an argument: --init-md FILE" >&2
          exit 1
        fi
        ;;

      # :flag.case
      --resume)

        # :flag.case_arg
        if [[ -n ${2+x} ]]; then
          args['--resume']="$2"
          shift
          shift
        else
          printf "%s\n" "--resume requires an argument: --resume SESSION_ID" >&2
          exit 1
        fi
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.environment_variables_filter

  env_var_names+=("ZION_NIXOS_DIR")
  env_var_names+=("OBSIDIAN_PATH")

  # :command.command_filter
  action=${1:-}

  case $action in

    continue | cont)
      action="continue"
      shift
      zion_continue_parse_requirements "$@"
      shift $#
      ;;

    new | run | r | open | opencode | code)
      action="new"
      shift
      zion_new_parse_requirements "$@"
      shift $#
      ;;

    shell | sh)
      action="shell"
      shift
      zion_shell_parse_requirements "$@"
      shift $#
      ;;

    resume)
      action="resume"
      shift
      zion_resume_parse_requirements "$@"
      shift $#
      ;;

    start)
      action="start"
      shift
      zion_start_parse_requirements "$@"
      shift $#
      ;;

    build)
      action="build"
      shift
      zion_build_parse_requirements "$@"
      shift $#
      ;;

    down)
      action="down"
      shift
      zion_down_parse_requirements "$@"
      shift $#
      ;;

    destroy)
      action="destroy"
      shift
      zion_destroy_parse_requirements "$@"
      shift $#
      ;;

    update | install)
      action="update"
      shift
      zion_update_parse_requirements "$@"
      shift $#
      ;;

    init)
      action="init"
      shift
      zion_init_parse_requirements "$@"
      shift $#
      ;;

    puppy | p)
      action="puppy"
      shift
      zion_puppy_parse_requirements "$@"
      shift $#
      ;;

    docker | dk)
      action="docker"
      shift
      zion_docker_parse_requirements "$@"
      shift $#
      ;;

    new-task | task-new)
      action="new-task"
      shift
      zion_new_task_parse_requirements "$@"
      shift $#
      ;;

    edit)
      action="edit"
      shift
      zion_edit_parse_requirements "$@"
      shift $#
      ;;

    help)
      action="help"
      shift
      zion_help_parse_requirements "$@"
      shift $#
      ;;

    man)
      action="man"
      shift
      zion_man_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    *)
      action="continue"
      zion_continue_parse_requirements "$@"
      shift $#
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

  # :command.default_assignments
  [[ -n ${args['--init-md']:-} ]] || args['--init-md']="contexto.md"

}

