# Configuração do zion — copie para ~/.zion e ajuste (chmod 600 ~/.zion)
# Este arquivo é sourceado pelo CLI; use sintaxe shell KEY=value.
# Nunca commite ~/.zion (contém tokens).

# ── Engine e modelo (--engine e --model na linha de comando sobrescrevem)
# opencode = OpenCode TUI | claude = Claude Code | cursor = Cursor
engine=claude

# Modelo padrão global: haiku | opus | sonnet (vazio = sonnet)
# model=sonnet

# Modelo por engine (sobrescreve model= para o engine específico)
# Shorthand: haiku | opus | sonnet. Aceita também ID completo (ex: claude-opus-4-6).
# model_claude=opus
# model_opencode=claude-sonnet-4-6
# model_cursor=haiku

# ── Tokens (injetados no container; use sempre menor escopo possível)
#
# GitHub Fine-grained PAT (read-only)
#   1. https://github.com/settings/personal-access-tokens/new
#   2. Token name: zion-agent (ou qualquer)
#   3. Resource owner: estrategiahq (ou sua org)
#   4. Repository access: All repositories (ou selecionar os repos)
#   5. Permissions (Repository):
#      - Contents: Read-only
#      - Pull requests: Read-only
#      - Issues: Read-only
#   6. Generate token → copiar aqui
GH_TOKEN=

# Anthropic (Claude API)
#   https://console.anthropic.com/settings/keys → Create Key
ANTHROPIC_API_KEY=

# ── Opcionais
# Caminho do vault Obsidian (default: $HOME/.ovault/Zion)
# OBSIDIAN_PATH=$HOME/.ovault/Zion

# Grafana (read-only — Service Account Token com role Viewer)
#   1. Abrir https://grafana.platform.estrategia.io
#   2. Menu lateral → Administration → Service Accounts
#   3. Add Service Account → nome: zion-agent, role: Viewer
#   4. Add service account token → copiar (prefixo glsa_)
#   Viewer = somente leitura (dashboards, datasources, logs Loki)
# GRAFANA_URL=https://grafana.platform.estrategia.io
# GRAFANA_TOKEN=glsa_xxxxxxxxxxxx

# Danger sempre ligado (equiv. a passar --danger em todo run/resume/continue)
# DANGER=true

# Raiz do repo NixOS (default: $HOME/nixos)
# ZION_NIXOS_DIR=$HOME/nixos
