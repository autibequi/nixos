flowchart TD
    classDef commit fill:#313244,stroke:#89b4fa,color:#cdd6f4
    classDef working fill:#1e1e2e,stroke:#89b4fa,color:#89b4fa,font-weight:bold
    classDef cmd fill:#181825,stroke:#a6e3a1,color:#a6e3a1,font-family:monospace,font-size:12px
    classDef forbidden fill:#2a1a1a,stroke:#f38ba8,color:#f38ba8,font-size:11px
    classDef bookmark fill:#1e1e2e,stroke:#f9e2af,color:#f9e2af
    classDef remote fill:#1a1a2e,stroke:#cba6f7,color:#cba6f7
    classDef oplog fill:#1a1a2e,stroke:#fab387,color:#fab387
    classDef tip fill:#181825,stroke:#585b70,color:#a6adc8,font-size:11px,font-style:italic

    subgraph WKCOPY["💾  Working Copy — sem staging area"]
        direction TB
        WC["📄 arquivos no disco"]:::working
        TIP1["qualquer edição já é parte\ndo commit atual (@)"]:::tip
    end

    subgraph HISTORY["🔗  Histórico Local"]
        direction TB
        A["● A  change:abc123\n'feat: base'"]:::commit
        B["● B  change:def456\n'feat: helper'"]:::commit
        AT["◉ @  change:ghi789\n'(sem desc)'  ← working copy"]:::working
        A --> B --> AT

        BM["🔖 bookmark\nfeat/minha-feature"]:::bookmark
        BM -.->|aponta para| AT

        SPLIT["jj split\ndivide @ em 2"]:::cmd
        SQUASH["jj squash\n@ absorve no pai"]:::cmd
        DESC["jj describe -m 'msg'\natualiza mensagem"]:::cmd
        NEWC["jj new\nnovo commit acima de @"]:::cmd
        EDIT["jj edit B\nvolta a editar B\n(@ move pra B)"]:::cmd
    end

    subgraph REBASE["♻️  Rebase — automático em descendentes"]
        direction LR
        RB1["jj rebase -d main\nmove @ em cima de main"]:::cmd
        RB2["descendentes\nrebased automaticamente"]:::tip
        RB1 --> RB2
    end

    subgraph CONFLICTS["⚔️  Conflitos — não bloqueiam"]
        direction TB
        CF1["jj rebase\n(mesmo com conflitos)"]:::cmd
        CF2["conflito fica\nno arquivo como marker"]:::tip
        CF3["jj resolve\nresolver quando quiser"]:::cmd
        CF1 --> CF2 --> CF3
    end

    subgraph OPLOG["🕐  Operation Log — undo ilimitado"]
        direction TB
        OL1["jj op log\nver todo o histórico"]:::oplog
        OL2["jj undo\ndesfaz última op"]:::oplog
        OL3["jj op restore ID\nvoltar a qualquer estado"]:::oplog
        OL1 --- OL2 --- OL3
    end

    subgraph REMOTE["☁️  Remote — GitHub / GitLab"]
        direction TB
        GF["jj git fetch\natualizar remotos"]:::remote
        GP["jj git push\n--bookmark feat/minha-feature"]:::remote
        PR["gh pr create\nabrir Pull Request"]:::remote
        GF --> GP --> PR
    end

    subgraph FORBIDDEN["❌  Comandos inexistentes / proibidos em repos jj"]
        direction LR
        F1["git add"]:::forbidden
        F2["git stash"]:::forbidden
        F3["git branch"]:::forbidden
        F4["git worktree"]:::forbidden
        F5["git commit"]:::forbidden
    end

    WC -->|"snapshot automático\na cada comando jj"| AT
    AT --> SPLIT
    AT --> SQUASH
    AT --> DESC
    AT --> NEWC
    B --> EDIT

    HISTORY -->|"jj rebase"| REBASE
    HISTORY -->|"conflito ao rebasar"| CONFLICTS
    HISTORY -->|"algo errou"| OPLOG
    HISTORY -->|"pronto pra publicar"| REMOTE

    style WKCOPY fill:#0d1117,stroke:#89b4fa
    style HISTORY fill:#0d1117,stroke:#a6e3a1
    style REBASE fill:#0d1117,stroke:#fab387
    style CONFLICTS fill:#0d1117,stroke:#f38ba8
    style OPLOG fill:#0d1117,stroke:#fab387
    style REMOTE fill:#0d1117,stroke:#cba6f7
    style FORBIDDEN fill:#1a0d0d,stroke:#f38ba8
