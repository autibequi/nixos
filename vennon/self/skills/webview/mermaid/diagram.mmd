%%{init: {'theme': 'dark', 'themeVariables': { 'fontSize': '15px' }}}%%
flowchart TB

  subgraph USR["Usuário"]
    direction LR
    pedro(["Pedro"]) -->|"prompt / feedback"| cli["Claude Code CLI\n(terminal)"]
  end

  subgraph CTR["Container vennon"]
    direction TB

    agent["Claude / Agente"]

    subgraph CTOOLS["Ferramentas de relay no container"]
      direction LR
      relay_py["chrome-relay.py\nnav / show / inject / tabs / status"]
      buzz_cli["buzz socket client\nrelay-nav / relay-show / relay-inject"]
      mmd_srv["mermaid_live_server.py :9876\nPOST /mermaid-push  →  SSE /mermaid-live"]
      content_srv["Content server :8766\n/tmp/chrome-relay/\nHTML, assets estáticos"]
    end

    agent -->|"Bash / chrome-relay.py"| relay_py
    agent -->|"buzz(...)"| buzz_cli
    agent -->|"curl POST /mermaid-push"| mmd_srv
    relay_py --- content_srv
  end

  subgraph HOST["Host"]
    direction LR
    cdp["Chrome CDP :9222\nWebSocket DevTools"]
    buzz_daemon["relay daemon\nbuzz host-side"]
    chrome["Chrome Browser"]

    cdp -->|"DevTools Protocol"| chrome
    buzz_daemon -->|"IPC nav / inject / tabs"| chrome
  end

  cli --> agent
  relay_py -->|"WebSocket CDP"| cdp
  buzz_cli -->|"Unix socket IPC"| buzz_daemon
  content_srv -.->|"HTTP GET  assets / HTML"| chrome
  mmd_srv -.->|"serve base.html"| chrome
  chrome -->|"SSE subscription\n/mermaid-live"| mmd_srv

  classDef box fill:#313244,stroke:#585b70,color:#cdd6f4
  classDef entry fill:#cba6f7,color:#1e1e2e,font-weight:bold
  classDef srv fill:#89b4fa,color:#1e1e2e
  classDef browser fill:#a6e3a1,color:#1e1e2e,font-weight:bold

  class pedro entry
  class cli,agent box
  class relay_py,buzz_cli,mmd_srv,content_srv srv
  class cdp,buzz_daemon box
  class chrome browser

  style USR fill:#1e1e2e,stroke:#f9e2af,stroke-width:2px,color:#cdd6f4
  style CTR fill:#1e1e2e,stroke:#89b4fa,stroke-width:2px,color:#cdd6f4
  style CTOOLS fill:#181825,stroke:#585b70,stroke-width:1px,stroke-dasharray:4 4,color:#a6adc8
  style HOST fill:#1e1e2e,stroke:#a6e3a1,stroke-width:2px,color:#cdd6f4
