{
  "env": {
    "TZ": "UTC+3"
  },
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__*",
      "ToolSearch(*)",
      "Agent(*)",
      "Skill(*)",
      "AskUserQuestion(*)",
      "TaskCreate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "TaskUpdate(*)",
      "NotebookEdit(*)",
      "CronCreate(*)",
      "CronDelete(*)",
      "CronList(*)",
      "EnterPlanMode(*)",
      "ExitPlanMode(*)",
      "EnterWorktree(*)",
      "ExitWorktree(*)",
      "ListMcpResourcesTool(*)",
      "ReadMcpResourceTool(*)",
      "RemoteTrigger(*)",
      "LSP(*)",
      "SendMessage(*)"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "nixos"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-tool-use.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/user-prompt-submit.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -d .jj ]] && jj status 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f /tmp/claude-arrivederchi ] && rm -f /tmp/claude-arrivederchi && kill $PPID || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[[ -d .jj ]] && jj show --summary 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "skipAutoPermissionPrompt": true
}
