install_dir := env("HOME") / ".local/bin"
nix_run := "nix-shell -p rustc cargo clippy rustfmt --run"

# Build both binaries (release)
build:
    {{nix_run}} "cargo build --release"

# Build debug
dev:
    {{nix_run}} "cargo build"

# Run all tests
test:
    {{nix_run}} "cargo test"

# Lint
clippy:
    {{nix_run}} "cargo clippy -- -W clippy::all"

# Format
fmt:
    {{nix_run}} "cargo fmt"

# Check formatting
fmt-check:
    {{nix_run}} "cargo fmt --check"

# Full check
check: build test clippy fmt-check

# Install all binaries to ~/.local/bin
install: build
    mkdir -p {{install_dir}}
    install -m 755 target/release/vennon {{install_dir}}/vennon
    install -m 755 target/release/yaa {{install_dir}}/yaa
    install -m 755 target/release/deck {{install_dir}}/deck
    @echo "installed vennon + yaa + deck → {{install_dir}}"

# Uninstall
uninstall:
    rm -f {{install_dir}}/vennon {{install_dir}}/yaa {{install_dir}}/deck

# Build all container images
images:
    podman build -t vennon-leech containers/leech/
    podman build -t vennon-claude containers/claude/
    podman build -t vennon-cursor containers/cursor/
    podman build -t vennon-opencode containers/opencode/

# Build single container image
image name:
    podman build -t vennon-{{name}} containers/{{name}}/

# Full install: binaries + images
all: install images

# Clean
clean:
    {{nix_run}} "cargo clean"
