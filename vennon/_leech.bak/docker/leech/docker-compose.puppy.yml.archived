x-env-base: &env-base
  PATH: /home/claude/.local/bin:/home/claude/.nix-profile/bin:/workspace/self/cli:/usr/bin:/bin
  ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY:-}
  CURSOR_API_KEY: ${CURSOR_API_KEY:-}
  CLAUDE_SESSION: ${CLAUDE_SESSION:-}
  GH_TOKEN: ${GH_TOKEN:-}
  GRAFANA_URL: ${GRAFANA_URL:-}
  GRAFANA_TOKEN: ${GRAFANA_TOKEN:-}
  CLAUDE_ENV: container
  WAYLAND_DISPLAY: ${WAYLAND_DISPLAY:-wayland-1}
  XDG_RUNTIME_DIR: /run/user/1000
  DISABLE_AUTOUPDATER: false
  # Docker autonomy: host paths for container→host translation
  ZION_NIXOS_DIR: ${HOME}/nixos
  HOST_HOME: ${HOME}
  HOST_PROJECTS_DIR: ${HOME}/projects
  HOST_NIXOS_DIR: ${HOME}/nixos

x-env-worker: &env-worker
  <<: *env-base
  ANTHROPIC_ADMIN_KEY: ${ANTHROPIC_ADMIN_KEY:-}

x-extra-hosts: &extra-hosts
  - "host.docker.internal:host-gateway"

x-base-volumes: &base-volumes
  - ${ZION_ROOT:-${HOME}/nixos/self}:/workspace/self
  - ${OBSIDIAN_PATH:-${HOME}/.ovault/Work}:/workspace/obsidian
  - ${CLAUDIO_MOUNT:-${HOME}/projects}:/workspace/mnt:${CLAUDIO_MOUNT_OPTS:-rw}
  - ${HOME}/.claude:/home/claude/.claude
  - ${ZION_ROOT:-${HOME}/nixos/self}/skills:/home/claude/.claude/skills
  - ${ZION_ROOT:-${HOME}/nixos/self}/commands:/home/claude/.claude/commands
  - ${ZION_ROOT:-${HOME}/nixos/self}/agents:/home/claude/.claude/agents
  - ${ZION_ROOT:-${HOME}/nixos/self}/hooks:/home/claude/.claude/hooks:ro
  - ${ZION_ROOT:-${HOME}/nixos/self}/scripts:/home/claude/.claude/scripts
  - ${HOME}/.claude.json:/home/claude/.claude.json
  - ${HOME}/.cursor:/home/claude/.cursor
  - ${ZION_ROOT:-${HOME}/nixos/self}/skills:/home/claude/.cursor/skills
  - ${ZION_ROOT:-${HOME}/nixos/self}/commands:/home/claude/.cursor/rules
  - cursor_config:/home/claude/.config/cursor
  - ${ZION_ROOT:-${HOME}/nixos/self}/.opencode:/home/claude/.config/opencode
  - ${HOME}/projects:/home/claude/projects
  - ${XDG_RUNTIME_DIR:-/run/user/1000}/${WAYLAND_DISPLAY:-wayland-1}:/run/user/1000/${WAYLAND_DISPLAY:-wayland-1}
  - /proc/meminfo:/host/proc/meminfo:ro
  - /proc/loadavg:/host/proc/loadavg:ro
  - /proc/uptime:/host/proc/uptime:ro
  - /proc/cpuinfo:/host/proc/cpuinfo:ro
  - /proc/version:/host/proc/version:ro
  - /run/current-system:/host/run/current-system:ro
  - /etc/os-release:/host/etc/os-release:ro
  - /tmp/zion-hive-mind:/workspace/.hive-mind
  # Logs de servicos Docker (zion docker run/test) — acessiveis pelo agente
  - ${XDG_DATA_HOME:-${HOME}/.local/share}/zion/logs/dockerized:/workspace/logs/docker:rw
  # Docker socket — permite agente gerenciar containers (zion docker run/install/logs)
  - /var/run/docker.sock:/var/run/docker.sock
  # Dockerized configs — agente pode editar docker-compose, .env, etc.
  - ${HOME}/.local/share/zion/dockerized:/workspace/dockerized
  # Mirror mounts: host paths acessiveis dentro do container (Docker build context + daemon volumes)
  - ${HOME}/projects:${HOME}/projects
  - ${HOME}/nixos:${HOME}/nixos:ro
  # Nix store compartilhado: persiste entre resets e evita re-download de pacotes
  - nix_store:/nix

services:
  puppy:
    image: claude-nix-sandbox
    cpus: "14.4"
    mem_limit: 12g
    memswap_limit: 12g
    stdin_open: true
    tty: true
    network_mode: host
    working_dir: /workspace/mnt
    entrypoint: ["/entrypoint.sh"]
    command: ["/bin/bash", "-c", "mkdir -p /workspace/obsidian/agents/cron 2>/dev/null; sleep 30 && exec /workspace/self/scripts/task-daemon.sh"]
    restart: unless-stopped
    group_add:
      - "${DOCKER_GID:-999}"
    # Isolation: drop all caps except what nix-daemon + gosu need
    cap_drop:
      - NET_RAW
      - SYS_PTRACE
      - SYS_RAWIO
      - MKNOD
      - AUDIT_WRITE
      - NET_BIND_SERVICE
    environment:
      <<: *env-worker
      GIT_AUTHOR_NAME: Buchecha
      GIT_AUTHOR_EMAIL: buchecha@autibequi.com
      GIT_COMMITTER_NAME: Buchecha
      GIT_COMMITTER_EMAIL: buchecha@autibequi.com
    extra_hosts: *extra-hosts
    volumes: *base-volumes

volumes:
  cursor_config:
  nix_store:

networks:
  default:
    name: nixos_default
    external: true
