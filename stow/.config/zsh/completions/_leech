#compdef vennon
# Zsh completion for vennon CLI (gerado a partir de bashly.yml)

_vennon_engines() { compadd claude opencode cursor }
_vennon_models()  { compadd haiku sonnet opus }
# Descobre servicos a partir do diretorio dockerized (exclui _shared e reverseproxy)
_vennon_docker_services() {
  local nixos_dir="${NIXOS_DIR:-$HOME/nixos}"
  local dockerized_dir="$nixos_dir/vennon/dockerized"
  if [[ -d "$dockerized_dir" ]]; then
    local services=()
    for d in "$dockerized_dir"/*/; do
      local name="${d%/}"
      name="${name##*/}"
      [[ "$name" == _* || "$name" == "reverseproxy" ]] && continue
      services+=("$name")
    done
    compadd -a services
  else
    compadd monolito bo-container front-student
  fi
}
_vennon_docker_envs()     { compadd sand prod qa local }
_vennon_puppy_models()    { compadd haiku sonnet opus }

_vennon_session_flags=(
  '--engine[Engine da sessão]:engine:_vennon_engines'
  '--model[Modelo Claude]:model:_vennon_models'
  '--instance[Sufixo da instância]:id'
  '--rw[Montar read-write]'
  '--ro[Montar read-only]'
  '--danger[Bypass de permissões]'
  '--init-md[Arquivo markdown inicial]:file:_files'
  '--resume[Retoma sessão]:session_id'
)

_vennon() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Ajuda]' \
    '(-v --version)'{-v,--version}'[Versão]' \
    '1: :_vennon_commands' \
    '*:: :->args'

  case $state in
    args)
      case $words[1] in
        continue|cont)
          _arguments ':dir:_files -/' ;;

        new|run|r|open|code)
          _arguments \
            $_vennon_session_flags \
            ':dir:_files -/' ;;

        shell|sh)
          _arguments ':dir:_files -/' ;;

        resume)
          _arguments \
            '--resume[UUID da sessão]:session_id' \
            ':dir:_files -/' ;;

        claude)
          _arguments '1: :_vennon_claude_commands' '*:: :->claude_args'
          case $state in
            claude_args)
              case $words[1] in
                new|'')
                  _arguments \
                    $_vennon_session_flags \
                    ':dir:_files -/' ;;
                usage|u)
                  _arguments \
                    '--waybar[Formato Waybar JSON]' \
                    '--json[JSON bruto]' \
                    '--refresh[Força fetch, ignora cache]' ;;
              esac ;;
          esac ;;

        cursor)
          _arguments \
            $_vennon_session_flags \
            ':dir:_files -/' ;;

        opencode|oc)
          _arguments \
            $_vennon_session_flags \
            ':dir:_files -/' ;;

        ask)
          _arguments \
            '--headless[Modo headless]' \
            '--timeout[Timeout em segundos]:seconds' \
            '--model[Modelo]:model:_vennon_puppy_models' \
            ':prompt' ;;

        set)
          _arguments ':engine:_vennon_engines' ;;

        new-task|task-new)
          _arguments \
            '--type[Tipo]:type:(pending recurring)' \
            '--model[Modelo]:model:_vennon_models' \
            '--clock[Frequência]:clock:(every10 every60)' \
            '--timeout[Timeout]:timeout' \
            ':name' ;;

        edit)
          _arguments \
            '--engine[Engine]:engine:_vennon_engines' \
            '--resume[Retoma sessão]:session_id' ;;

        clean|gc|prune)
          _arguments '--force[Sem confirmação]' ;;

        puppy|p)
          _arguments '1: :_vennon_puppy_commands' '*:: :->puppy_args'
          case $state in
            puppy_args)
              case $words[1] in
                run)
                  _arguments ':task' ;;
                logs)
                  _arguments '--follow[Follow log output]' '-f[Follow log output]' ;;
                query|q)
                  _arguments \
                    '--headless[Modo headless]' \
                    '--timeout[Timeout]:seconds' \
                    '--model[Modelo]:model:_vennon_puppy_models' \
                    ':prompt' ;;
              esac ;;
          esac ;;

        docker|dk)
          _arguments '1: :_vennon_docker_services' '*:: :->docker_service_args'
          case $state in
            docker_service_args)
              local service="$words[1]"
              _arguments '1: :_vennon_docker_service_ops' '*:: :->docker_op_args'
              case $state in
                docker_op_args)
                  case $words[1] in
                    install)
                      _arguments \
                        '--env[Ambiente]:env:_vennon_docker_envs' \
                        '-e[Ambiente]:env:_vennon_docker_envs' \
                        '--worktree[Worktree]:name' '-w[Worktree]:name' ;;
                    shell)
                      _arguments \
                        '--container[Container]:container:(app db redis)' \
                        '-c[Container]:container:(app db redis)' \
                        '--cmd[Comando]:cmd' \
                        '--worktree[Worktree]:name' '-w[Worktree]:name' ;;
                    logs)
                      _arguments \
                        '--follow[Seguir em tempo real]' '-f[Follow]' \
                        '--tail[Linhas]:n' '-t[Linhas]:n' \
                        '--worktree[Worktree]:name' '-w[Worktree]:name' ;;
                    build|flush)
                      _arguments \
                        '--worktree[Worktree]:name' '-w[Worktree]:name' ;;
                    server|worker)
                      _arguments '1: :_vennon_docker_server_ops' '*:: :->server_op_args'
                      case $state in
                        server_op_args)
                          case $words[1] in
                            start|up)
                              _arguments \
                                '--env[Ambiente]:env:_vennon_docker_envs' \
                                '-e[Ambiente]:env:_vennon_docker_envs' \
                                '--detach[Background]' '-d[Background]' \
                                '--debug[Modo debug]' \
                                '--worktree[Worktree]:name' '-w[Worktree]:name' \
                                ${service:+$( [[ "$service" == "front-student" ]] && echo '--vertical[Vertical]:vertical -V[Vertical]:vertical' )} ;;
                            stop|down)
                              _arguments \
                                '--worktree[Worktree]:name' '-w[Worktree]:name' ;;
                          esac ;;
                      esac ;;
                  esac ;;
              esac ;;
          esac ;;

        worktree|wt)
          _arguments ':service:_vennon_docker_services' ;;
      esac ;;
  esac
}

_vennon_claude_commands() {
  local commands=(
    'new:Nova sessão Claude (padrão)'
    'usage:Estatísticas de uso Claude'
  )
  _describe 'subcomando claude' commands
}

_vennon_docker_service_ops() {
  local ops=(
    'install:Instala dependências'
    'shell:Shell no container'
    'logs:Logs do serviço'
    'status:Status dos containers'
    'build:Rebuilda a imagem'
    'flush:Remove containers e volumes'
    'server:Gerencia o servidor'
    'worker:Gerencia o worker (monolito)'
  )
  _describe 'operação' ops
}

_vennon_docker_server_ops() {
  local ops=(
    'start:Sobe o serviço'
    'stop:Para o serviço'
  )
  _describe 'ação' ops
}

_vennon_commands() {
  local commands=(
    'continue:Continua a última sessão'
    'new:Nova sessão no container'
    'shell:Bash no container'
    'resume:Lista sessões e escolhe qual retomar'
    'claude:Nova sessão com engine Claude'
    'cursor:Nova sessão com engine Cursor'
    'opencode:Nova sessão com engine OpenCode'
    'ask:Envia prompt ao Puppy'
    'puppy:Gerencia o Puppy worker'
    'docker:Gerencia serviços Docker'
    'worktree:Lista worktrees dos serviços'
    'new-task:Cria task no kanban'
    'set:Define engine padrão'
    'status:Status agregado'
    'edit:Abre sessão com ~/nixos'
    'build:Build da imagem Docker'
    'down:Para todos os containers'
    'destroy:Para containers e remove imagens'
    'clean:Remove sessões paradas'
    'update:Regenera CLI e atualiza symlink'
    'init:Cria ~/.vennon'
    'help:Mostra banner com comandos'
    'man:Documentação completa'
  )
  _describe 'comando' commands
}

_vennon_puppy_commands() {
  local commands=(
    'start:Inicia o container puppy'
    'stop:Para o container puppy'
    'restart:Reinicia o container puppy'
    'run:Roda uma task específica'
    'status:Estado do container e tasks'
    'logs:Logs do container puppy'
    'shell:Bash dentro do container puppy'
    'tick:Roda 1 tick do scheduler'
    'query:Envia prompt ao Claude no puppy'
  )
  _describe 'subcomando puppy' commands
}


_vennon "$@"
