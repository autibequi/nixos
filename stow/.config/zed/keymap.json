// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
	{
		"bindings": {
			// Quick Shortcuts
			"ctrl-shift-q": "debug_panel::Toggle",
			// VSCode Like
			"ctrl-p": "file_finder::Toggle",
			"ctrl-u": "outline::Toggle",
			// Panels WASD Management
			"ctrl-shift-w": "workspace::CloseAllDocks",
			"ctrl-shift-a": "workspace::ToggleLeftDock",
			"ctrl-shift-s": "workspace::ToggleBottomDock",
			"ctrl-shift-d": "workspace::ToggleRightDock",
			// Open Projects
			"ctrl-shift-r": "projects::OpenRecent",
			"alt-enter": "agent::AllowOnce",
			"alt-shift-enter": "agent::RejectOnce"
		}
	},
	// ─── Terminal: Ctrl+C → SIGINT (não interceptar no AgentPanel) ─
	// Zed captura ctrl-c no AgentPanel antes de chegar ao terminal;
	// forçar SendText  no contexto Terminal garante SIGINT.
	{
		"context": "Terminal",
		"bindings": {
			"ctrl-c": null,
			"ctrl-s": null
		}
	},
	// Default do Zed re-binda ctrl-alt-t dentro do AgentPanel; soltar.
	{
		"context": "AgentPanel && acp_thread",
		"unbind": {
			"ctrl-alt-t": "agent::NewThread"
		}
	},
	// ─── Unbind padrão do plugin multi_workspace ───────────────────
	{
		"context": "Workspace",
		"unbind": {
			"ctrl-alt-j": "multi_workspace::ToggleWorkspaceSidebar"
		}
	},
	// ─── Font size — bindings dedicados ─────────────────────────────
	// Ctrl+Shift+(=/-/0) → só buffer  ·  Ctrl+Alt+(=/-/0) → só UI
	// Ctrl+Shift+Alt+0 → reset zoom do agent panel
	{
		"bindings": {
			"ctrl-shift-=": "zed::IncreaseBufferFontSize",
			"ctrl-_": "zed::DecreaseBufferFontSize",
			"ctrl-shift-0": "zed::ResetBufferFontSize",
			"ctrl-alt-=": "zed::IncreaseUiFontSize",
			"ctrl-alt--": "zed::DecreaseUiFontSize",
			"ctrl-alt-0": "zed::ResetUiFontSize",
			"ctrl-shift-alt-0": "agent::ResetAgentZoom"
		}
	},
	// ─── Font size — macro "tudo junto" estilo VSCode ──────────────
	// Ctrl+= / Ctrl+- / Ctrl+0 dispara as duas keystrokes acima em sequência.
	// Se algum dia parar de funcionar (SendKeystrokes muda de comportamento),
	// remover este bloco e usar diretamente as Ctrl+Shift+/Ctrl+Alt+ separadas.
	{
		"bindings": {
			"ctrl-=": [
				"workspace::SendKeystrokes",
				"ctrl-shift-= ctrl-alt-="
			],
			"ctrl--": [
				"workspace::SendKeystrokes",
				"ctrl-_ ctrl-alt--"
			],
			"ctrl-0": [
				"workspace::SendKeystrokes",
				"ctrl-shift-0 ctrl-alt-0"
			]
		}
	}
]
