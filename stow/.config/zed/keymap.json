// Zed keymap — Pedro
//
// Cluster mão-esquerda para toggles de painel (Q W E R T / A S D F G / Z X C V B).
// Mão direita fica livre pro mouse.
//
// Docs: https://zed.dev/docs/key-bindings
// Default keymap: command palette → "zed: open default keymap"
[
	// ─── Docks home-row (A S D) + Workspaces (W) + Zen (Z) ────────
	{
		"bindings": {
			"ctrl-shift-a": "workspace::ToggleLeftDock",
			"ctrl-shift-s": "workspace::ToggleBottomDock",
			"ctrl-shift-d": "workspace::ToggleRightDock",
			"ctrl-shift-w": "multi_workspace::ToggleWorkspaceSidebar",
			"ctrl-shift-z": "workspace::ToggleZoom"
		}
	},
	// ─── Painéis específicos (cluster esquerdo) ────────────────────
	// Q = debug   E = explorer   R = recent   T = threads/agent
	// F = find    G = git        X = diagnostics   B = outline
	{
		"bindings": {
			"ctrl-shift-q": "debug_panel::Toggle",
			"ctrl-shift-e": "project_panel::ToggleFocus",
			"ctrl-shift-r": "projects::OpenRecent",
			"ctrl-shift-t": "agent::ToggleFocus",
			"ctrl-shift-f": "project_search::ToggleFocus",
			"ctrl-shift-g": "git_panel::ToggleFocus",
			"ctrl-shift-x": "diagnostics::Deploy",
			"ctrl-shift-b": "outline_panel::ToggleFocus"
		}
	},
	// ─── LAYOUTS (Ctrl+Alt — action::Sequence) ─────────────────────
	// Cada layout começa com CloseAllDocks (zera) e reabre só os docks do
	// preset → determinístico, não depende do estado atual. Se algum atalho
	// colidir com o Hyprland, trocar a letra aqui.
	{
		"bindings": {
			// Code: explorer (esquerda) + terminal (baixo)
			"ctrl-alt-c": [
				"action::Sequence",
				[
					"workspace::CloseAllDocks",
					"project_panel::ToggleFocus",
					"workspace::ToggleBottomDock"
				]
			],
			// Review: git panel
			"ctrl-alt-r": [
				"action::Sequence",
				[
					"workspace::CloseAllDocks",
					"git_panel::ToggleFocus"
				]
			],
			// AI: agent / threads
			"ctrl-alt-i": [
				"action::Sequence",
				[
					"workspace::CloseAllDocks",
					"agent::ToggleFocus"
				]
			],
			// Zen: fecha tudo + abas inativas + centered layout (toggle)
			"ctrl-alt-z": [
				"action::Sequence",
				[
					"workspace::CloseAllDocks",
					"workspace::CloseInactiveTabsAndPanes",
					"workspace::ToggleCenteredLayout"
				]
			]
		}
	},
	// ─── Quick access genéricos ────────────────────────────────────
	{
		"bindings": {
			"ctrl-p": "file_finder::Toggle",
		}
	},
	// ─── Agent / Threads ───────────────────────────────────────────
	{
		"bindings": {
			"ctrl-alt-t": "agent::NewThread",
			"ctrl-alt-shift-t": "agent::ToggleNewThreadMenu",
			"alt-enter": "agent::AllowOnce",
			"alt-shift-enter": "agent::RejectOnce"
		}
	},
	// ─── Terminal: Ctrl+C = copiar · Ctrl+Shift+C = SIGINT (invertido) ─
	// Igual Alacritty/Ghostty: ctrl-c copia; ctrl-shift-c reenvia o ^C real
	// pro shell via SendKeystroke (fonte: zed#21262).
	// ATENCAO: ctrl-c SEM selecao NAO cancela — use ctrl-shift-c.
	{
		"context": "Terminal",
		"bindings": {
			"ctrl-c": "terminal::Copy",
			"ctrl-shift-c": ["terminal::SendKeystroke", "ctrl-c"],
			"ctrl-s": null
		}
	},
	// Default do Zed re-binda ctrl-alt-t dentro do AgentPanel; soltar.
	{
		"context": "AgentPanel && acp_thread",
		"unbind": {
			"ctrl-alt-t": "agent::NewThread"
		}
	},
	// ─── Unbind padrão do plugin multi_workspace ───────────────────
	{
		"context": "Workspace",
		"unbind": {
			"ctrl-alt-j": "multi_workspace::ToggleWorkspaceSidebar"
		}
	},
	// ─── Font size — bindings dedicados ─────────────────────────────
	// Ctrl+Shift+(=/-/0) → só buffer  ·  Ctrl+Alt+(=/-/0) → só UI
	// Ctrl+Shift+Alt+0 → reset zoom do agent panel
	{
		"bindings": {
			"ctrl-shift-=": "zed::IncreaseBufferFontSize",
			"ctrl-_": "zed::DecreaseBufferFontSize",
			"ctrl-shift-0": "zed::ResetBufferFontSize",
			"ctrl-alt-=": "zed::IncreaseUiFontSize",
			"ctrl-alt--": "zed::DecreaseUiFontSize",
			"ctrl-alt-0": "zed::ResetUiFontSize",
			"ctrl-shift-alt-0": "agent::ResetAgentZoom"
		}
	},
	// ─── Font size — macro "tudo junto" estilo VSCode ──────────────
	// Ctrl+= / Ctrl+- / Ctrl+0 dispara as duas keystrokes acima em sequência.
	// Se algum dia parar de funcionar (SendKeystrokes muda de comportamento),
	// remover este bloco e usar diretamente as Ctrl+Shift+/Ctrl+Alt+ separadas.
	{
		"bindings": {
			"ctrl-=": [
				"workspace::SendKeystrokes",
				"ctrl-shift-= ctrl-alt-="
			],
			"ctrl--": [
				"workspace::SendKeystrokes",
				"ctrl-_ ctrl-alt--"
			],
			"ctrl-0": [
				"workspace::SendKeystrokes",
				"ctrl-shift-0 ctrl-alt-0"
			]
		}
	},
	// ─── LSP: reset rápido (monorepo coruja trava/derruba o gopls) ─
	// Ctrl+Shift+Delete reinicia o language server do buffer atual.
	// Use quando o gopls travar (hung) — o Zed não tem watchdog pra isso.
	{
		"context": "Editor",
		"bindings": {
			"ctrl-shift-delete": "editor::RestartLanguageServer"
		}
	}
]
