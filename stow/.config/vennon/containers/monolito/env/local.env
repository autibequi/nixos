# Monolito — APP_ENV=local (config Go) rodando *dentro* do stack vennon (compose).
# Os serviços postgres/redis/localstack são alcançáveis pelos nomes dos services.
APP_ENV=local
APP_PORT=4004

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=estrategia
DB_PASSWORD=estrategia
DB_NAME=estrategia
DB_SSLMODE=disable

# Redis — obrigatório: o monolito usa REDIS_URL (ver configuration.go), não só REDIS_HOST.
# Sem isso, .env.sandbox deixa REDIS_URL=localhost:6379 e o app no container fala com [::1].
REDIS_URL=monolito-redis:6379
REDIS_STUDY_TIME_URL=monolito-redis:6379
REDIS_HOST=monolito-redis
REDIS_PORT=6379

# AWS / LocalStack
AWS_ENDPOINT=http://localstack:4566
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Logging
LOG_LEVEL=debug
