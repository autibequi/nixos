# Monolito — QA environment
APP_ENV=qa
APP_PORT=4004

# Database — serviço compose na rede vennon
DB_HOST=postgres
DB_PORT=5432
DB_USER=estrategia
DB_PASSWORD=estrategia
DB_NAME=estrategia
DB_SSLMODE=disable

# Redis (o monolito lê REDIS_URL / REDIS_STUDY_TIME_URL)
REDIS_URL=redis:6379
REDIS_STUDY_TIME_URL=redis:6379

AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Logging
LOG_LEVEL=info
