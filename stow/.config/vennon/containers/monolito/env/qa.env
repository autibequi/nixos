# Monolito — QA environment
APP_ENV=qa
APP_PORT=4004

# Database (override via .env.local ou ~/.zion)
DB_HOST=vennon-dk-monolito-postgres
DB_PORT=5432
DB_USER=estrategia
DB_PASSWORD=estrategia
DB_NAME=estrategia
DB_SSLMODE=disable

# Redis
REDIS_HOST=vennon-dk-monolito-redis
REDIS_PORT=6379

# Logging
LOG_LEVEL=info
