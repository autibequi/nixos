# Stack vennon — mesma rede Docker que local/sand (deps no compose).
APP_ENV=devbox
APP_PORT=4004

DB_HOST=postgres
DB_PORT=5432
DB_USER=estrategia
DB_PASSWORD=estrategia
DB_NAME=estrategia
DB_SSLMODE=disable

REDIS_URL=monolito-redis:6379
REDIS_STUDY_TIME_URL=monolito-redis:6379

AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

LOG_LEVEL=debug
