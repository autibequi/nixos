# Zion Docker overrides para sandbox
# Carregado DEPOIS do .env.sandbox do projeto — sobrescreve hosts para containers Docker

APP_ENV=sandbox
APP_PORT=4004

# Database — hostname = nome do serviço no docker-compose (DNS da rede compose)
DB_HOST=postgres
DB_PORT=5432
DB_USER=estrategia
DB_PASSWORD=estrategia
DB_NAME=estrategia
DB_SSLMODE=disable

# Redis — mesma rede: host redis (serviço compose)
REDIS_URL=redis:6379
REDIS_STUDY_TIME_URL=redis:6379

# LocalStack na rede compose (útil se APP_ENV apontar filas S3/SQS para 4566)
AWS_ENDPOINT_URL=http://localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
