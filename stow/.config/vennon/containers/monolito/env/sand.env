# Zion Docker overrides para sandbox
# Carregado DEPOIS do .env.sandbox do projeto — sobrescreve hosts para containers Docker

APP_ENV=sandbox
APP_PORT=4004

# Database — aponta para container Docker
DB_HOST=vennon-dk-monolito-postgres
DB_PORT=5432
DB_USER=estrategia
DB_PASSWORD=estrategia
DB_NAME=estrategia
DB_SSLMODE=disable

# Redis — aponta para container Docker
REDIS_URL=vennon-dk-monolito-redis:6379
REDIS_STUDY_TIME_URL=vennon-dk-monolito-redis:6379
