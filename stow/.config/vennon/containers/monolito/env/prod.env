# Monolito — production environment (template)
# Segredos reais devem vir de .env.local ou variavel de ambiente, nunca commitados.
APP_ENV=production
APP_PORT=4004

# Database
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=require

# Redis
REDIS_HOST=
REDIS_PORT=6379

# Logging
LOG_LEVEL=warn
