{
  "layer": "bottom",
  "position": "bottom",
  "spacing": 0,
  "margin": 0,
  "modules-left": [
    "idle_inhibitor",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "custom/swaync",
    "clock",
    "battery"
  ],
  "modules-right": [
    "mpris",
    "pulseaudio",
    "backlight",
    "network",
    "tray",
    "bluetooth"
  ],
  "tray": {
    "icon-size": 14,
    "spacing": 5,
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ïپ¬",
      "performance": "ïƒ§",
      "balanced": "ï‰ژ",
      "power-saver": "ïپ¬"
    }
  },
  "hyprland/workspaces": {
    "interval": 1,
    "disable-scroll": true,
    "all-outputs": false,
    "show-special": true,
    "format": "{icon}:{windows}",
    "tooltip": true,
    "tooltip-format": "{name}",
    "window-rewrite-default": "ïپ™",
    "format-icons": {
      "f8": "f8.settings",
      "bleh": "~.claudinho",
      "1": "1.code",
      "2": "2.test",
      "3": "3.web",
      // "f1": "ت•â– ل´¥â– ت”",
      // "f2": "ت•â– ل´¥â– ت”",
      // "f3": "ت•â– ل´¥â– ت”",
      // "f4": "ت•â– ل´¥â– ت”"
    },
    "workspace-taskbar": {
      "format": "{icon} {title}",
      "format-icons": {
        "default": "ïپ™ "
      },
      "tooltip": true
    },
    "window-rewrite": {
      "title<(.*[$%#] *)?([hb]|nv)top.*>": "btop",
      "title<(.* - )?(.[0-9]+. )?YouTube Music.*>": "ï…ھ",
      "title<(.*)(books - Obsidian)(.*)>": "ï€­",
      "class<(.*)(chat)(.*)>": "َ°چ،",
      "class<(Alacritty|ghostty)> title<(.*)(âœ³ Claude)(.*)>": "َ±™؛",
      "class<(.*)(chrome-claude)(.*)>": "âœ»",
      "title<(.*)(Gemini)(.*)>": "َ°¼™",
      "title<(.*)(JIRA)(.*)>": "َ°Œƒ",
      "title<(.*)(Meet)(.*)>": "ï‚•",
      "firefox": "ï‰©",
      "vivaldi": "ï‰©",
      "app.zen_browser.zen": "ï‰©",
      "zen": "ï‰©",
      "chrome": "ï‰¨",
      "dbeaver": "ًں¦«",
      "code": "َ°¨‍",
      "cursor": "َ°¨‍",
      "obsidian": "ï’ٹ",
      "Alacritty": "َ°†چ",
      "ghostty": "َ°†چ",
      "org.gnome.Nautilus": "ïپ¼",
      "zed": "َ°°¶",
      "stremio": "ًںچ؟",
      "insomnia": "ïˆ¶",
      "yaak-app": "َ°†ڑ",
      "class<^steam_app_.*>": "َ°®¯",
      "title<.*Steam.*>": "ï†¶"
    }
  },
  "mpris": {
    "format": "{player_icon} {title} - {artist}",
    "format-paused": "{status_icon} CALADO, MORTAL!",
    "max-length": 30,
    "tooltip-format": "{title} | {artist}",
    "player-icons": {
      "default": "â–¶",
      "firefox": "ï‰©",
      "chrome": "ï‰¨",
    },
    "status-icons": {
      "paused": "âڈ¸"
    },
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "َ°ˆˆ ",
      "deactivated": "َ°ˆ‰ "
    },
    "tooltip": true
  },
  "clock": {
    "format": "َ°¥” {:%H:%M:%S}",
    "interval": 1,
    "format-alt": "َ°ƒ® {:%Y-%m-%d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#d3c6aa'><b>{}</b></span>",
        "days": "<span color='#e67e80'>{}</span>",
        "weeks": "<span color='#a7c080'><b>W{}</b></span>",
        "weekdays": "<span color='#7fbbb3'><b>{}</b></span>",
        "today": "<span color='#dbbc7f'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "cpu": {
    "format": "َ°چ› {usage}%",
    "tooltip": true,
    "interval": 10
  },
  "memory": {
    "format": "َ°کڑ {}%",
    "interval": 1
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format-time": "{H}:{m}",
    "format": "| {icon} {time}",
    "format-charging": "َ°‚„ {capacity}%",
    "format-plugged": "َ°ڑ¥ {capacity}%",
    "format-icons": [
      "َ°‚ژe",
      "َ°پ؛E",
      "َ°پ»â…•",
      "َ°پ¼â…“",
      "َ°پ½â…–",
      "َ°پ¾آ½",
      "َ°پ؟â…—",
      "َ°‚€â…ک",
      "َ°‚پâ…ک",
      "َ°‚‚f",
      "َ°پ¹F"
    ]
  },
  "network": {
    "format-wifi": "َ°–© {signalStrength}%",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "format-linked": "َ°ˆ€ {ifname} (No IP)",
    "format-disconnected": "َ°–ھ Disconnected",
    "tooltip-format": "َ°–© {essid} : {ifname}: {ipaddr}",
    "on-click": "alacritty -e nmtui"
  },
  "bluetooth": {
    "format": "ïٹ”",
    "format-connected": "ïٹ” {device_alias}",
    "format-connected-battery": "ïٹ” {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "alacritty -e bluetuith"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "َ°‚° {volume}%",
    "format-bluetooth-muted": "َ°‚² {icon}",
    "format-muted": "َ°‌ں",
    "format-icons": {
      "headphone": "َ°‹‹",
      "hands-free": "َ°¥°",
      "headset": "َ°‹ژ",
      "phone": "َ°ڈ²",
      "portable": "َ°„‌",
      "car": "َ°„‹",
      "default": [
        "َ°•؟",
        "َ°–€",
        "َ°•¾"
      ]
    },
    "on-click": "alacritty -e wiremix",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "<span foreground='white'>َ°‚ڑ<sup></sup></span>",
      "none": "َ°‚œ",
      "dnd-notification": "<span foreground='white'>َ°‚›<sup></sup></span>",
      "dnd-none": "َ°‚›",
      "inhibited-notification": "<span foreground='white'>َ°‚ڑ<sup></sup></span>",
      "inhibited-none": "َ°‚œ",
      "dnd-inhibited-notification": "<span foreground='white'>َ°‚›<sup></sup></span>",
      "dnd-inhibited-none": "َ°‚›"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "َ°ƒ‍",
      "َ°ƒں",
      "َ°ƒ "
    ],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  }
}
