{
  "layer": "bottom",
  "position": "bottom",
  "spacing": 0,
  "margin": 0,
  "modules-left": [
    "idle_inhibitor",
    "hyprland/workspaces"
    // "hyprland/window"
  ],
  "modules-center": [
    "custom/swaync",
    "clock",
    "battery"
  ],
  "modules-right": [
    "mpris",
    "custom/cpu-bar",
    "custom/ram-bar",
    "custom/claude-usage",
    "pulseaudio",
    "backlight",
    "network",
    "tray",
    "bluetooth"
  ],
  "tray": {
    "icon-size": 14,
    "spacing": 2,
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    }
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "rewrite": {
      "Claude\\[(.+?)\\]:.*": "󱙺 $1",
      "(.*) — Claude.*": "󱙺 $1"
    }
  },
  "hyprland/workspaces": {
    "interval": 1,
    "disable-scroll": true,
    "all-outputs": false,
    "show-special": true,
    "special-visible-only": false,
    "persistent-workspaces": {
      "*": ["special:f1", "special:f2", "special:f3", "special:f4", "special:f5", "special:f6", "special:f7", "special:f8"]
    },
    "format": "{icon}{windows}</span>",
    "tooltip": true,
    "tooltip-format": "{name}",
    "window-rewrite-default": "",
    "escape": false,
    "format-icons": {
      "f1": "<span foreground='#e74c3c'>F1: ",
      "f2": "<span foreground='#e67e22'>F2: ",
      "f3": "<span foreground='#f1c40f'>F3: ",
      "f4": "<span foreground='#2ecc71'>F4: ",
      "f5": "<span foreground='#1abc9c'>F5: ",
      "f6": "<span foreground='#3498db'>F6: ",
      "f7": "<span foreground='#9b59b6'>F7: ",
      "f8": "<span foreground='#e056fd'>f8: ",
      "bleh": "<span>~: ",
      "1": "<span>1:",
      "2": "<span>2:",
      "3": "<span>3",
      "4": "<span>4:",
      "5": "<span>5:",
      "6": "<span>6:",
      "7": "<span>7:",
      "8": "<span>8:",
      "9": "<span>9:",
      "10": "<span>10:",
      "gemini": "<span>gemini: ",
      "default": "<span>"
    },
    "workspace-taskbar": {
      "format": "{icon} {title}",
      "format-icons": {
        "default": " "
      },
      "tooltip": true
    },
    "window-rewrite": {
      "title<(.*[$%#] *)?([hb]|nv)top.*>": "btop",
      "title<(.* - )?(.[0-9]+. )?YouTube Music.*>": "",
      "title<(.*)(books - Obsidian)(.*)>": "",
      "class<(.*)(chat)(.*)>": "󰍡",
      "class<(Alacritty|ghostty)> title<(.*)(✳ Claude)(.*)>": "󱙺",
      "class<(.*)(chrome-claude)(.*)>": "✻",
      "title<(.*)(Gemini)(.*)>": "󰼙",
      "title<(.*)(JIRA)(.*)>": "󰌃",
      "title<(.*)(Meet)(.*)>": "",
      "firefox": "",
      "vivaldi": "",
      "app.zen_browser.zen": "",
      "zen": "",
      "chrome": "",
      "dbeaver": "🦫",
      "code": "󰨞",
      "cursor": "󰨞",
      "obsidian": "",
      "Alacritty": "󰆍",
      "ghostty": "󰆍",
      "org.gnome.Nautilus": "",
      "zed": "󰰶",
      "stremio": "🍿",
      "insomnia": "",
      "yaak-app": "󰆚",
      "class<^steam_app_.*>": "󰮯",
      "title<.*Steam.*>": ""
    }
  },
  "mpris": {
    "format": "{player_icon} {title} - {artist}",
    "format-paused": "{status_icon} CALADO, MORTAL!",
    "max-length": 30,
    "tooltip-format": "{title} | {artist}",
    "player-icons": {
      "default": "▶",
      "firefox": "",
      "chrome": "",
    },
    "status-icons": {
      "paused": "⏸"
    },
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "󰈈 ",
      "deactivated": "󰈉 "
    },
    "tooltip": true
  },
  "clock": {
    "format": "󰥔 {:%H:%M:%S}",
    "interval": 1,
    "format-alt": "󰃮 {:%Y-%m-%d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#d3c6aa'><b>{}</b></span>",
        "days": "<span color='#e67e80'>{}</span>",
        "weeks": "<span color='#a7c080'><b>W{}</b></span>",
        "weekdays": "<span color='#7fbbb3'><b>{}</b></span>",
        "today": "<span color='#dbbc7f'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "cpu": {
    "format": "󰍛 {usage}%",
    "tooltip": true,
    "interval": 10
  },
  "memory": {
    "format": "󰘚 {}%",
    "interval": 1
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format-time": "{H}:{m}",
    "format": "| {icon} {time}",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰚥 {capacity}%",
    "format-icons": [
      "󰂎e",
      "󰁺E",
      "󰁻⅕",
      "󰁼⅓",
      "󰁽⅖",
      "󰁾½",
      "󰁿⅗",
      "󰂀⅘",
      "󰂁⅘",
      "󰂂f",
      "󰁹F"
    ]
  },
  "network": {
    "format-wifi": "󰖩 {signalStrength}%",
    "format-ethernet": "󰈀 {ifname}",
    "format-linked": "󰈀 {ifname} (No IP)",
    "format-disconnected": "󰖪 Disconnected",
    "tooltip-format": "󰖩 {essid} : {ifname}: {ipaddr}",
    "on-click": "alacritty -e nmtui"
  },
  "bluetooth": {
    "format": "",
    "format-connected": " {device_alias}",
    "format-connected-battery": " {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "alacritty -e bluetuith"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "󰂰 {volume}%",
    "format-bluetooth-muted": "󰂲 {icon}",
    "format-muted": "󰝟",
    "format-icons": {
      "headphone": "󰋋",
      "hands-free": "󰥰",
      "headset": "󰋎",
      "phone": "󰏲",
      "portable": "󰄝",
      "car": "󰄋",
      "default": [
        "󰕿",
        "󰖀",
        "󰕾"
      ]
    },
    "on-click": "alacritty -e wiremix",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
  },
  "custom/claude": {
    "format": "{}",
    "interval": 300,
    "exec": "claude-statusbar --plan max20 2>/dev/null || \"${HOME}/.claude/scripts/claude-ai-usage.sh\" 2>/dev/null || echo '󱙺 --'",
    "tooltip": true,
    "on-click": "alacritty -e bash -c 'claude-statusbar --plan max20; read'"
  },
  "custom/claude-usage": {
    "exec": "zion claude-usage --waybar 2>/dev/null || echo \"{\\\"text\\\":\\\" 󱙺 --\\\",\\\"tooltip\\\":\\\"Claude: erro ao rodar script\\\",\\\"class\\\":\\\"\\\"}\"",
    "return-type": "json",
    "interval": 15,
    "signal": 8,
    "on-click": "zion claude-usage --waybar --refresh; pkill -RTMIN+8 waybar",
    "format": "{}",
    "tooltip": true,
    "escape": false
  },
  "custom/cpu-bar": {
    "exec": "$HOME/.config/waybar/waybar-resource-bar.sh cpu",
    "return-type": "json",
    "interval": 2,
    "format": "{}",
    "tooltip": true,
    "escape": false
  },
  "custom/gpu-bar": {
    "exec": "$HOME/.config/waybar/waybar-resource-bar.sh gpu",
    "return-type": "json",
    "interval": 2,
    "format": "{}",
    "tooltip": true,
    "escape": false
  },
  "custom/ram-bar": {
    "exec": "$HOME/.config/waybar/waybar-resource-bar.sh memory",
    "return-type": "json",
    "interval": 2,
    "format": "{}",
    "tooltip": true,
    "escape": false
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "<span foreground='white'>󰂚<sup></sup></span>",
      "none": "󰂜",
      "dnd-notification": "<span foreground='white'>󰂛<sup></sup></span>",
      "dnd-none": "󰂛",
      "inhibited-notification": "<span foreground='white'>󰂚<sup></sup></span>",
      "inhibited-none": "󰂜",
      "dnd-inhibited-notification": "<span foreground='white'>󰂛<sup></sup></span>",
      "dnd-inhibited-none": "󰂛"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "󰃞",
      "󰃟",
      "󰃠"
    ],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  }
}
