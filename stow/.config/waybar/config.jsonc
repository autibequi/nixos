{
	"layer": "bottom",
	"position": "bottom",
	"height": 26,
	"spacing": 0,
	"margin": 0,
	"modules-left": [
		"idle_inhibitor",
		// "custom/vennon",
		"hyprland/workspaces"
		// "hyprland/window"
	],
	"modules-center": [
		"custom/screenrecord",
		"custom/swaync",
		"clock",
		"battery"
	],
	"modules-right": [
		"mpris",
		"custom/claude-usage",
		"custom/obsidian-sync",
		"pulseaudio",
		"backlight",
		"custom/ddcutil-brightness",
		"network",
		"tray",
		"bluetooth"
	],
	"tray": {
		"icon-size": 14,
		"spacing": 2
	},
	"custom/screenrecord": {
		"exec": "[ -f /tmp/screenrecord.pid ] && echo '{\"text\":\"¾░æŖ REC\",\"tooltip\":\"Recording... click to stop\",\"class\":\"active\"}' || echo '{\"text\":\"\",\"tooltip\":\"\",\"class\":\"\"}'",
		"return-type": "json",
		"interval": 2,
		"signal": 9,
		"format": "{}",
		"on-click": "screenrecord-toggle"
	},
	"group/tray-expander": {
		"orientation": "horizontal",
		"drawer": {
			"transition-duration": 300,
			"children-class": "tray-drawer",
			"transition-left-to-right": false
		},
		"modules": [
			"custom/tray-toggle",
			"tray"
		]
	},
	"custom/tray-toggle": {
		"format": "",
		"tooltip-format": "Expand tray",
		"interval": "once"
	},
	"power-profiles-daemon": {
		"format": "{icon}",
		"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
		"tooltip": true,
		"format-icons": {
			"default": "’ü¼",
			"performance": "’ā¦",
			"balanced": "’ēÄ",
			"power-saver": "’ü¼"
		}
	},
	"hyprland/window": {
		"format": "{}",
		"max-length": 50,
		"rewrite": {
			"Claude\\[(.+?)\\]:.*": "¾▒Ö║ $1",
			"(.*) ŌĆö Claude.*": "¾▒Ö║ $1"
		}
	},
	"hyprland/workspaces": {
		"interval": 1,
		"disable-scroll": true,
		"all-outputs": false,
		"show-special": true,
		"special-visible-only": false,
		"persistent-workspaces": {},
		"format": "{icon}{windows}</span>",
		"tooltip": true,
		"tooltip-format": "{name}",
		"window-rewrite-default": "’üÖ",
		"escape": false,
		"format-icons": {
			"f1": "<span foreground='#b05450'>F1: ",
			"f2": "<span foreground='#a87240'>F2: ",
			"f3": "<span foreground='#9a8838'>F3: ",
			"f4": "<span foreground='#429960'>F4: ",
			"f5": "<span foreground='#369088'>F5: ",
			"f6": "<span foreground='#4070a8'>F6: ",
			"f7": "<span foreground='#7058a0'>F7: ",
			"f8": "<span foreground='#8040a8'>F8: ",
			"f9": "<span foreground='#8040a8'>F9: ",
			"f10": "<span foreground='#8040a8'>F10: ",
			"bleh": "<span>~: ",
			"1": "<span>1:",
			"2": "<span>2:",
			"3": "<span>3",
			"4": "<span>4:",
			"5": "<span>5:",
			"6": "<span>6:",
			"7": "<span>7:",
			"8": "<span>8:",
			"9": "<span>9:",
			"10": "<span>10:",
			"gemini": "<span>gemini: ",
			"default": "<span>"
		},
		"workspace-taskbar": {
			"format": "{icon} {title}",
			"format-icons": {
				"default": "’üÖ "
			},
			"tooltip": true
		},
		"window-rewrite": {
			"title<(.*[$%#] *)?([hb]|nv)top.*>": "btop",
			"title<(.* - )?(.[0-9]+. )?YouTube Music.*>": "’ģ¬",
			"title<(.*)(books - Obsidian)(.*)>": "’ĆŁ",
			"class<(.*)(chat)(.*)>": "¾░ŹĪ",
			"class<(Alacritty|ghostty)> title<(.*)(Ō£│ Claude)(.*)>": "¾▒Ö║",
			"class<(.*)(chrome-claude)(.*)>": "Ō£╗",
			"title<(.*)(Gemini)(.*)>": "¾░╝Ö",
			"title<(.*)(JIRA)(.*)>": "¾░īā",
			"title<(.*)(Meet)(.*)>": "’éĢ",
			"firefox": "’ē®",
			"vivaldi": "’ē®",
			"app.zen_browser.zen": "’ē®",
			"zen": "’ē®",
			"chrome": "’ē©",
			"dbeaver": "­¤”½",
			"code": "¾░©×",
			"cursor": "¾░©×",
			"obsidian": "’ÆŖ",
			"Alacritty": "¾░åŹ",
			"ghostty": "¾░åŹ",
			"org.gnome.Nautilus": "’ü╝",
			"zed": "¾░░Č",
			"stremio": "­¤Ź┐",
			"insomnia": "’łČ",
			"yaak-app": "¾░åÜ",
			"class<^steam_app_.*>": "¾░«»",
			"title<.*Steam.*>": "’åČ"
		}
	},
	"mpris": {
		"format": "{player_icon} {title} - {artist}",
		"format-paused": "{status_icon} CALADO, MORTAL!",
		"max-length": 30,
		"tooltip-format": "{title} | {artist}",
		"player-icons": {
			"default": "Ō¢Č",
			"firefox": "’ē®",
			"chrome": "’ē©",
		},
		"status-icons": {
			"paused": "ŌÅĖ"
		},
		"on-click": "playerctl play-pause",
		"on-click-right": "playerctl next",
		"on-scroll-up": "playerctl next",
		"on-scroll-down": "playerctl previous"
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "¾░ģČ ",
			"deactivated": "¾░ģĘ "
		},
		"tooltip": true
	},
	"clock": {
		"format": "¾░źö {:%H:%M}",
		"interval": 60,
		"format-alt": "¾░ā« {:%Y-%m-%d}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"calendar": {
			"mode": "month",
			"mode-mon-col": 3,
			"weeks-pos": "right",
			"on-scroll": 1,
			"on-click-right": "mode",
			"format": {
				"months": "<span color='#d3c6aa'><b>{}</b></span>",
				"days": "<span color='#e67e80'>{}</span>",
				"weeks": "<span color='#a7c080'><b>W{}</b></span>",
				"weekdays": "<span color='#7fbbb3'><b>{}</b></span>",
				"today": "<span color='#dbbc7f'><b><u>{}</u></b></span>"
			}
		},
		"actions": {
			"on-click-right": "mode",
			"on-click-forward": "tz_up",
			"on-click-backward": "tz_down",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		}
	},
	"cpu": {
		"format": "¾░Źø {usage}%",
		"tooltip": true,
		"interval": 10
	},
	"memory": {
		"format": "¾░śÜ {}%",
		"interval": 1
	},
	"battery": {
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{m}",
		"format": "{icon}{capacity}% {time}",
		"format-charging": "¾░éä {capacity}%",
		"format-plugged": "¾░Üź {capacity}%",
		"format-icons": [
			"¾░éÄ",
			"¾░ü║",
			"¾░ü╗",
			"¾░ü╝",
			"¾░üĮ",
			"¾░üŠ",
			"¾░ü┐",
			"¾░éĆ",
			"¾░éü",
			"¾░éé",
			"¾░ü╣"
		]
	},
	"network": {
		"format-wifi": "¾░¢® {signalStrength}%",
		"format-ethernet": "¾░łĆ {ifname}",
		"format-linked": "¾░łĆ {ifname} (No IP)",
		"format-disconnected": "¾░¢¬ Disconnected",
		"tooltip-format": "¾░¢® {essid} : {ifname}: {ipaddr}",
		"on-click": "alacritty -e nmtui"
	},
	"bluetooth": {
		"format": "’Ŗö",
		"format-connected": "’Ŗö {device_alias}",
		"format-connected-battery": "’Ŗö {device_alias} {device_battery_percentage}%",
		"tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
		"on-click": "alacritty -e bluetuith"
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-bluetooth": "¾░é░ {volume}%",
		"format-bluetooth-muted": "¾░é▓ {icon}",
		"format-muted": "¾░Ø¤",
		"format-icons": {
			"headphone": "¾░ŗŗ",
			"hands-free": "¾░ź░",
			"headset": "¾░ŗÄ",
			"phone": "¾░Å▓",
			"portable": "¾░äØ",
			"car": "¾░äŗ",
			"default": [
				"¾░Ģ┐",
				"¾░¢Ć",
				"¾░ĢŠ"
			]
		},
		"on-click": "alacritty -e wiremix",
		"on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
		"on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
	},
	"custom/claude-usage": {
		"exec": "plug claude usage --waybar",
		"return-type": "json",
		"interval": 60,
		"signal": 8,
		"on-click": "xdg-open https://claude.ai/settings/usage",
		"on-click-right": "plug claude usage --refresh --waybar; pkill -RTMIN+8 waybar",
		"format": "{}",
		"tooltip": true,
		"escape": false,
		"markup": "pango"
	},
	"custom/obsidian-sync": {
		"exec": "$HOME/.config/waybar/obsidian-sync-status.sh",
		"return-type": "json",
		"interval": 30,
		"format": "{}",
		"tooltip": true,
		"escape": false,
		"on-click": "alacritty -e bash -c '$HOME/.config/waybar/obsidian-sync-panel.sh'",
		"on-click-right": "alacritty -e journalctl -u obsidian-sync -f"
	},
	"custom/cpu-bar": {
		"exec": "$HOME/.config/waybar/waybar-resource-bar.sh cpu",
		"return-type": "json",
		"interval": 2,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},
	"custom/gpu-bar": {
		"exec": "$HOME/.config/waybar/waybar-resource-bar.sh gpu",
		"return-type": "json",
		"interval": 2,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},
	"custom/ram-bar": {
		"exec": "$HOME/.config/waybar/waybar-resource-bar.sh memory",
		"return-type": "json",
		"interval": 2,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},
	"custom/swaync": {
		"tooltip": false,
		"format": "{icon} {text}",
		"format-icons": {
			"notification": "<span foreground='white'>¾░éÜ<sup></sup></span>",
			"none": "¾░é£",
			"dnd-notification": "<span foreground='white'>¾░éø<sup></sup></span>",
			"dnd-none": "¾░éø",
			"inhibited-notification": "<span foreground='white'>¾░éÜ<sup></sup></span>",
			"inhibited-none": "¾░é£",
			"dnd-inhibited-notification": "<span foreground='white'>¾░éø<sup></sup></span>",
			"dnd-inhibited-none": "¾░éø"
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	},
	"custom/ddcutil-brightness": {
		"exec": "$HOME/.config/waybar/ddcutil-brightness.sh",
		"return-type": "json",
		"interval": 10,
		"signal": 10,
		"format": "{}",
		"tooltip": true,
		"on-scroll-up": "flock -n /tmp/ddcutil.lock $HOME/.config/waybar/ddcutil-scroll.sh up && pkill -RTMIN+10 waybar",
		"on-scroll-down": "flock -n /tmp/ddcutil.lock $HOME/.config/waybar/ddcutil-scroll.sh down && pkill -RTMIN+10 waybar"
	},
	"backlight": {
		"format": "{icon} {percent}%",
		"format-icons": [
			"¾░ā×",
			"¾░ā¤",
			"¾░āĀ"
		],
		"on-scroll-up": "brightnessctl set +5%",
		"on-scroll-down": "brightnessctl set 5%-"
	}
}
