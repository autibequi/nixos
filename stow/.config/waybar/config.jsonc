{
	"layer": "top",
	"position": "bottom",
	"height": 24,
	"spacing": 0,
	"margin": "3px 5px 3px",
	"modules-left": [
		"custom/caffeine",
		// "custom/vennon",
		"hyprland/workspaces",
		"hyprland/workspaces#special",
		"mpris"
		// "hyprland/window"
	],
	"modules-center": [
		"custom/cliptoast",
		"custom/screenrecord",
		"custom/todoist",
		"custom/swaync",
		"custom/chicote",
		"custom/clock",
		"battery",
		"custom/pr-approved",
		"custom/pr-pending",
		"custom/pr-review"
	],
	"modules-right": [
		"custom/claude-usage",
		"group/system-controls",
		"tray",
		"bluetooth"
	],
	"group/system-controls": {
		"orientation": "horizontal",
		"modules": [
			"pulseaudio",
			"backlight",
			"custom/ddcutil-brightness",
			"network"
		]
	},
	"tray": {
		"icon-size": 14,
		"spacing": 2
	},
	"custom/todoist": {
		"exec": "bash $HOME/.config/quickshell/modules/todoist/todoist-panel.sh status 2>/dev/null || printf '{\"text\":\"َ°„²\",\"class\":\"\",\"tooltip\":\"\"}'",
		"return-type": "json",
		"interval": 60,
		"signal": 15,
		"format": "{}",
		"on-click": "qs ipc call todoist toggle",
		"tooltip": true
	},
	"custom/cliptoast": {
		"exec": "cat /tmp/waybar-cliptoast.json 2>/dev/null || echo '{\"text\":\"\"}'",
		"return-type": "json",
		"interval": "once",
		"signal": 13,
		"escape": false,
		"format": "{}"
	},
	"custom/screenrecord": {
		"exec": "[ -f /tmp/screenrecord.pid ] && echo '{\"text\":\"َ°‘ٹ REC\",\"tooltip\":\"Recording... click to stop\",\"class\":\"active\"}' || echo '{\"text\":\"\",\"tooltip\":\"\",\"class\":\"\"}'",
		"return-type": "json",
		"interval": 2,
		"signal": 9,
		"format": "{}",
		"on-click": "screenrecord-toggle"
	},
	"custom/chicote": {
		"exec": "pgrep -x chicote >/dev/null && echo '{\"text\":\"ًں¥پ\",\"class\":\"active\"}' || echo '{\"text\":\"\",\"class\":\"\"}'",
		"return-type": "json",
		"interval": 2,
		"signal": 12,
		"format": "{}",
		"escape": false,
		"on-click": "$HOME/.config/hypr/chicote-toggle.sh"
	},
	"custom/special-workspaces": {
		"exec": "cat /tmp/waybar-specials.json 2>/dev/null || echo '{\"text\":\"\",\"class\":\"empty\"}'",
		"return-type": "json",
		"interval": 30,
		"signal": 11,
		"format": "{}",
		"escape": false,
		"tooltip": true,
		"on-click": "hyprctl dispatch togglespecialworkspace"
	},
	"group/tray-expander": {
		"orientation": "horizontal",
		"drawer": {
			"transition-duration": 300,
			"children-class": "tray-drawer",
			"transition-left-to-right": false
		},
		"modules": [
			"custom/tray-toggle",
			"tray"
		]
	},
	"custom/tray-toggle": {
		"format": "",
		"tooltip-format": "Expand tray",
		"interval": "once"
	},
	"power-profiles-daemon": {
		"format": "{icon}",
		"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
		"tooltip": true,
		"format-icons": {
			"default": "ïپ¬",
			"performance": "ïƒ§",
			"balanced": "ï‰ژ",
			"power-saver": "ïپ¬"
		}
	},
	"hyprland/window": {
		"format": "{}",
		"max-length": 50,
		"rewrite": {
			"Claude\\[(.+?)\\]:.*": "َ±™؛ $1",
			"(.*) â€” Claude.*": "َ±™؛ $1",
			"[âœ³â گ] (.+)": "َ±™؛ $1"
		}
	},
	"hyprland/workspaces": {
		"interval": 1,
		"disable-scroll": true,
		"all-outputs": true,
		"move-to-monitor": false,
		"show-special": false,
		"persistent-workspaces": {},
		"format": "{icon}{windows}</span>",
		"on-click": "activate",
		"tooltip": true,
		"tooltip-format": "{name}",
		"window-rewrite-default": "ïپ™",
		"escape": false,
		"format-icons": {
			"f1": "<span foreground='#b05450'>F1: ",
			"f2": "<span foreground='#a87240'>F2: ",
			"f3": "<span foreground='#9a8838'>F3: ",
			"f4": "<span foreground='#429960'>F4: ",
			"f5": "<span foreground='#369088'>F5: ",
			"f6": "<span foreground='#4070a8'>F6: ",
			"f7": "<span foreground='#7058a0'>F7: ",
			"f8": "<span foreground='#8040a8'>F8: ",
			"f9": "<span foreground='#8040a8'>F9: ",
			"f10": "<span foreground='#8040a8'>F10: ",
			"bleh": "<span>~: ",
			"1": "<span>1:",
			"2": "<span>2:",
			"3": "<span>3",
			"4": "<span>4:",
			"5": "<span>5:",
			"6": "<span>6:",
			"7": "<span>7:",
			"8": "<span>8:",
			"9": "<span>9:",
			"10": "<span>10:",
			"gemini": "<span>gemini: ",
			"default": "<span>"
		},
		"workspace-taskbar": {
			"format": "{icon} {title}",
			"format-icons": {
				"default": "ïپ™ "
			},
			"tooltip": true
		},
		"window-rewrite": {
			"title<(.*[$%#] *)?([hb]|nv)top.*>": "َ°“…",
			"title<(.* - )?(.[0-9]+. )?YouTube Music.*>": "ï…ھ",
			"title<(.*)(books - Obsidian)(.*)>": "ï€­",
			"class<(.*)(chat)(.*)>": "َ°چ،",
			"class<(Alacritty|ghostty)> title<(.*)(âœ³ )(.*)>": "َ±™؛",
			"class<(Alacritty|ghostty)> title<\\xe2[\\xa0-\\xa3][\\x80-\\xbf] >": "َ±™؛",
			"class<(Alacritty|ghostty)> title<^(n?vim)>": "َ°•·",
			"class<(Alacritty|ghostty)> title<^(node|npm|pnpm|bun)>": "َ°ژ™",
			"class<(Alacritty|ghostty)> title<^(go|make)>": "َ°ں“",
			"class<(Alacritty|ghostty)> title<^(git|tig|lazygit)>": "َ°ٹ¢",
			"class<(Alacritty|ghostty)> title<^(docker|podman)>": "َ°،¨",
			"class<(Alacritty|ghostty)> title<^(ssh|mosh)>": "َ°Œک",
			"class<(Alacritty|ghostty)> title<^(python|python3)>": "َ°Œ ",
			"class<(.*)(chrome-claude)(.*)>": "âœ»",
			"title<(.*)(Gemini)(.*)>": "َ°¼™",
			"title<(.*)(JIRA)(.*)>": "َ°Œƒ",
			"title<(.*)(Meet)(.*)>": "َ°”¨",
			"firefox": "ï‰©",
			"vivaldi": "ï‰©",
			"app.zen_browser.zen": "ï‰©",
			"zen": "ï‰©",
			"chrome": "ï‰¨",
			"chromium": "ï‰¨",
			"dbeaver": "ًں¦«",
			"code": "َ°¨‍",
			"cursor": "َ°¨‍",
			"obsidian": "ï’ٹ",
			"Alacritty": "َ°†چ",
			"ghostty": "َ°†چ",
			"org.gnome.Nautilus": "ïپ¼",
			"zed": "ً‌—­",
			"stremio": "ًںچ؟",
			"insomnia": "ïˆ¶",
			"yaak-app": "َ°†ڑ",
			"class<^steam_app_.*>": "َ°®¯",
			"title<.*Steam.*>": "ï†¶"
		}
	},
	"hyprland/workspaces#special": {
		"disable-scroll": true,
		"all-outputs": true,
		"move-to-monitor": false,
		"show-special": true,
		"persistent-workspaces": {},
		"on-click": "activate",
		"format": "{icon}{windows}</span>",
		"tooltip": true,
		"tooltip-format": "{name}",
		"window-rewrite-default": "",
		"escape": false,
		"format-icons": {
			"f1": "<span>F1:",
			"f2": "<span>F2:",
			"f3": "<span>F3:",
			"f4": "<span>F4:",
			"f5": "<span>F5:",
			"f6": "<span>F6:",
			"f7": "<span>F7:",
			"f8": "<span>F8:",
			"f9": "<span>F9:",
			"f10": "<span>F10:",
			"bleh": "<span>~:",
			"gemini": "<span>gemini:",
			"1": "<span>",
			"2": "<span>",
			"3": "<span>",
			"4": "<span>",
			"5": "<span>",
			"6": "<span>",
			"7": "<span>",
			"8": "<span>",
			"9": "<span>",
			"10": "<span>",
			"default": "<span>"
		},
		"window-rewrite": {
			"title<(.*[$%#] *)?([hb]|nv)top.*>": "َ°“…",
			"title<(.* - )?(.[0-9]+. )?YouTube Music.*>": "",
			"title<.* - Obsidian>": "ï€­",
			"class<(.*)(chat)(.*)>": "َ°چ،",
			"class<(Alacritty|ghostty)> title<(.*)(âœ³ )(.*)>": "َ±™؛",
			"class<(Alacritty|ghostty)> title<\\xe2[\\xa0-\\xa3][\\x80-\\xbf] >": "َ±™؛",
			"class<(Alacritty|ghostty)> title<^(n?vim)>": "َ°•·",
			"class<(Alacritty|ghostty)> title<^(node|npm|pnpm|bun)>": "َ°ژ™",
			"class<(Alacritty|ghostty)> title<^(go|make)>": "َ°ں“",
			"class<(Alacritty|ghostty)> title<^(git|tig|lazygit)>": "َ°ٹ¢",
			"class<(Alacritty|ghostty)> title<^(docker|podman)>": "َ°،¨",
			"class<(Alacritty|ghostty)> title<^(ssh|mosh)>": "َ°Œک",
			"class<(Alacritty|ghostty)> title<^(python|python3)>": "َ°Œ ",
			"class<(.*)(chrome-claude)(.*)>": "âœ»",
			"title<(.*)(Gemini)(.*)>": "َ°¼™",
			"title<(.*)(JIRA)(.*)>": "َ°Œƒ",
			"title<(.*)(Meet)(.*)>": "َ°”¨",
			"firefox": "ï‰©",
			"vivaldi": "ï‰©",
			"zen": "ï‰©",
			"chrome": "ï‰¨",
			"class<[Oo]bsidian>": "ï€­",
			"Alacritty": "َ°†چ",
			"ghostty": "َ°†چ",
			"zed": "َ°°¶"
		}
	},
	"mpris": {
		"format": "{player_icon} {title} - {artist}",
		"format-paused": "{status_icon} SHIIIIIU!",
		"max-length": 30,
		"tooltip-format": "{title} | {artist}",
		"player-icons": {
			"default": "â–¶",
			"firefox": "ï‰©",
			"chrome": "ï‰¨",
		},
		"status-icons": {
			"paused": "âڈ¸"
		},
		"on-click": "playerctl play-pause",
		"on-click-right": "playerctl next",
		"on-scroll-up": "playerctl next",
		"on-scroll-down": "playerctl previous"
	},
	"custom/caffeine": {
		"exec": "$HOME/.config/waybar/caffeine.sh status",
		"return-type": "json",
		"interval": 5,
		"on-click": "$HOME/.config/waybar/caffeine.sh toggle",
		"tooltip": true
	},
	"custom/clock": {
		"exec": "f=/tmp/wbclk; d=$(date +'%u'); w=${d/1/SEG}; w=${w/2/TER}; w=${w/3/QUA}; w=${w/4/QUI}; w=${w/5/SEX}; w=${w/6/SAB}; w=${w/7/DOM}; [ -f \"$f\" ] && date +\"$w  %Y-%m-%d  %H:%M:%S\" || date +'%H:%M'",
		"return-type": "",
		"interval": 1,
		"signal": 16,
		"format": "َ°¥” {}",
		"on-click": "qs ipc call clock toggle",
		"on-click-right": "f=/tmp/wbclk; [ -f \"$f\" ] && rm -f \"$f\" || touch \"$f\"; pkill -SIGRTMIN+16 waybar",
		"tooltip": false
	},
	"cpu": {
		"format": "َ°چ› {usage}%",
		"tooltip": true,
		"interval": 10
	},
	"memory": {
		"format": "َ°کڑ {}%",
		"interval": 5
	},
	"battery": {
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{m}",
		"format": "{icon}{capacity}% {time}",
		"format-charging": "َ°‚„ {capacity}%",
		"format-plugged": "َ°ڑ¥ {capacity}%",
		"format-icons": [
			"َ°‚ژ",
			"َ°پ؛",
			"َ°پ»",
			"َ°پ¼",
			"َ°پ½",
			"َ°پ¾",
			"َ°پ؟",
			"َ°‚€",
			"َ°‚پ",
			"َ°‚‚",
			"َ°پ¹"
		]
	},
	"network": {
		"format": "َ°¤«",
		"format-wifi": "َ°–© {signalStrength}%",
		"format-ethernet": "َ°ˆ€ {ifname}",
		"format-linked": "َ°ˆ€ {ifname} (No IP)",
		"format-disconnected": "َ°–ھ Disconnected",
		"format-disabled": "َ°¤® Wi-Fi off",
		"tooltip-format": "َ°–© {essid} : {ifname}: {ipaddr}",
		"tooltip-format-disconnected": "Sem conexأ£o â€” clique para gerenciar",
		"tooltip-format-disabled": "Wi-Fi desligado â€” clique para gerenciar",
		"on-click": "nmsurf",
		"on-click-right": "alacritty -e nmtui"
	},
	"bluetooth": {
		"format": "ïٹ”",
		"format-connected": "ïٹ” {device_alias}",
		"format-connected-battery": "ïٹ” {device_alias} {device_battery_percentage}%",
		"tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
		"on-click": "$HOME/.config/hypr/walker-launch.sh --theme neon --provider bluetooth",
		"on-click-right": "alacritty -e bluetuith"
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-bluetooth": "َ°‚° {volume}%",
		"format-bluetooth-muted": "َ°‚² {icon}",
		"format-muted": "َ°‌ں",
		"format-icons": {
			"headphone": "َ°‹‹",
			"hands-free": "َ°¥°",
			"headset": "َ°‹ژ",
			"phone": "َ°ڈ²",
			"portable": "َ°„‌",
			"car": "َ°„‹",
			"default": [
				"َ°•؟",
				"َ°–€",
				"َ°•¾"
			]
		},
		"on-click": "$HOME/.config/hypr/walker-launch.sh --provider wireplumber",
		"on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"on-click-middle": "alacritty -e wiremix",
		"on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
		"on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
	},
	"custom/claude-usage": {
		"exec": "yaa claude usage --waybar",
		"return-type": "json",
		"interval": 60,
		"signal": 8,
		"on-click": "qs ipc call usage toggle",
		"on-click-middle": "xdg-open https://claude.ai/settings/usage",
		"on-click-right": "yaa claude usage --refresh --waybar; pkill -RTMIN+8 waybar",
		"format": "{}",
		"tooltip": false,
		"escape": false,
		"markup": "pango"
	},
	"custom/obsidian-sync": {
		"exec": "$HOME/.config/waybar/obsidian-sync-status.sh",
		"return-type": "json",
		"interval": 30,
		"format": "{}",
		"tooltip": true,
		"escape": false,
		"on-click": "alacritty -e bash -c '$HOME/.config/waybar/obsidian-sync-panel.sh'",
		"on-click-right": "alacritty -e journalctl -u obsidian-sync -f"
	},
	"custom/cpu-bar": {
		"exec": "$HOME/.config/waybar/waybar-resource-bar.sh cpu",
		"return-type": "json",
		"interval": 2,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},
	"custom/gpu-bar": {
		"exec": "$HOME/.config/waybar/waybar-resource-bar.sh gpu",
		"return-type": "json",
		"interval": 2,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},
	"custom/ram-bar": {
		"exec": "$HOME/.config/waybar/waybar-resource-bar.sh memory",
		"return-type": "json",
		"interval": 2,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},
	"custom/pr-approved": {
		"exec": "$HOME/.config/waybar/git-prs.sh approved",
		"return-type": "json",
		"interval": 180,
		"on-click": "qs ipc call github toggle"
	},
	"custom/pr-pending": {
		"exec": "$HOME/.config/waybar/git-prs.sh pending",
		"return-type": "json",
		"interval": 180,
		"on-click": "qs ipc call github toggle"
	},
	"custom/pr-review": {
		"exec": "$HOME/.config/waybar/git-prs.sh review",
		"return-type": "json",
		"interval": 180,
		"on-click": "qs ipc call github toggle"
	},
	"custom/swaync": {
		"tooltip": false,
		"format": "{icon} {text}",
		"format-icons": {
			"notification": "<span foreground='white'>َ°‚ڑ<sup></sup></span>",
			"none": "َ°‚œ",
			"dnd-notification": "<span foreground='white'>َ°‚›<sup></sup></span>",
			"dnd-none": "َ°‚›",
			"inhibited-notification": "<span foreground='white'>َ°‚ڑ<sup></sup></span>",
			"inhibited-none": "َ°‚œ",
			"dnd-inhibited-notification": "<span foreground='white'>َ°‚›<sup></sup></span>",
			"dnd-inhibited-none": "َ°‚›"
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	},
	"custom/ddcutil-brightness": {
		"exec": "$HOME/.config/waybar/ddcutil-brightness.sh",
		"return-type": "json",
		"interval": 30,
		"signal": 10,
		"format": "{}",
		"tooltip": true,
		"on-scroll-up": "$HOME/.config/waybar/ddcutil-scroll.sh up && pkill -RTMIN+10 waybar",
		"on-scroll-down": "$HOME/.config/waybar/ddcutil-scroll.sh down && pkill -RTMIN+10 waybar"
	},
	"backlight": {
		"format": "{icon} {percent}%",
		"format-icons": [
			"َ°ƒ‍",
			"َ°ƒں",
			"َ°ƒ "
		],
		"on-scroll-up": "brightnessctl set +5%",
		"on-scroll-down": "brightnessctl set 5%-"
	}
}
