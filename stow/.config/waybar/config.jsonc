{
  "layer": "bottom",
  "position": "bottom",
  "spacing": 0,
  "margin": 0,
  "modules-left": [
    "idle_inhibitor",
    "hyprland/workspaces"
    // "hyprland/window"
  ],
  "modules-center": [
    "custom/swaync",
    "clock",
    "battery"
  ],
  "modules-right": [
    "mpris",
    "custom/claude-usage",
    "pulseaudio",
    "backlight",
    "network",
    "tray",
    "bluetooth"
  ],
  "tray": {
    "icon-size": 14,
    "spacing": 5,
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "’ü¼",
      "performance": "’ā¦",
      "balanced": "’ēÄ",
      "power-saver": "’ü¼"
    }
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "rewrite": {
      "Claude\\[(.+?)\\]:.*": "¾▒Ö║ $1",
      "(.*) ŌĆö Claude.*": "¾▒Ö║ $1"
    }
  },
  "hyprland/workspaces": {
    "interval": 1,
    "disable-scroll": true,
    "all-outputs": false,
    "show-special": true,
    "format": "{icon}:{windows}",
    "tooltip": true,
    "tooltip-format": "{name}",
    "window-rewrite-default": "’üÖ",
    "format-icons": {
      "f8": "f8.settings",
      "bleh": "~.claudinho",
      "1": "1.code",
      "2": "2.test",
      "3": "3.web",
      // "f1": "╩ĢŌ¢Āß┤źŌ¢Ā╩ö",
      // "f2": "╩ĢŌ¢Āß┤źŌ¢Ā╩ö",
      // "f3": "╩ĢŌ¢Āß┤źŌ¢Ā╩ö",
      // "f4": "╩ĢŌ¢Āß┤źŌ¢Ā╩ö"
    },
    "workspace-taskbar": {
      "format": "{icon} {title}",
      "format-icons": {
        "default": "’üÖ "
      },
      "tooltip": true
    },
    "window-rewrite": {
      "title<(.*[$%#] *)?([hb]|nv)top.*>": "btop",
      "title<(.* - )?(.[0-9]+. )?YouTube Music.*>": "’ģ¬",
      "title<(.*)(books - Obsidian)(.*)>": "’ĆŁ",
      "class<(.*)(chat)(.*)>": "¾░ŹĪ",
      "class<(Alacritty|ghostty)> title<(.*)(Ō£│ Claude)(.*)>": "¾▒Ö║",
      "class<(.*)(chrome-claude)(.*)>": "Ō£╗",
      "title<(.*)(Gemini)(.*)>": "¾░╝Ö",
      "title<(.*)(JIRA)(.*)>": "¾░īā",
      "title<(.*)(Meet)(.*)>": "’éĢ",
      "firefox": "’ē®",
      "vivaldi": "’ē®",
      "app.zen_browser.zen": "’ē®",
      "zen": "’ē®",
      "chrome": "’ē©",
      "dbeaver": "­¤”½",
      "code": "¾░©×",
      "cursor": "¾░©×",
      "obsidian": "’ÆŖ",
      "Alacritty": "¾░åŹ",
      "ghostty": "¾░åŹ",
      "org.gnome.Nautilus": "’ü╝",
      "zed": "¾░░Č",
      "stremio": "­¤Ź┐",
      "insomnia": "’łČ",
      "yaak-app": "¾░åÜ",
      "class<^steam_app_.*>": "¾░«»",
      "title<.*Steam.*>": "’åČ"
    }
  },
  "mpris": {
    "format": "{player_icon} {title} - {artist}",
    "format-paused": "{status_icon} CALADO, MORTAL!",
    "max-length": 30,
    "tooltip-format": "{title} | {artist}",
    "player-icons": {
      "default": "Ō¢Č",
      "firefox": "’ē®",
      "chrome": "’ē©",
    },
    "status-icons": {
      "paused": "ŌÅĖ"
    },
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "¾░łł ",
      "deactivated": "¾░łē "
    },
    "tooltip": true
  },
  "clock": {
    "format": "¾░źö {:%H:%M:%S}",
    "interval": 1,
    "format-alt": "¾░ā« {:%Y-%m-%d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#d3c6aa'><b>{}</b></span>",
        "days": "<span color='#e67e80'>{}</span>",
        "weeks": "<span color='#a7c080'><b>W{}</b></span>",
        "weekdays": "<span color='#7fbbb3'><b>{}</b></span>",
        "today": "<span color='#dbbc7f'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "cpu": {
    "format": "¾░Źø {usage}%",
    "tooltip": true,
    "interval": 10
  },
  "memory": {
    "format": "¾░śÜ {}%",
    "interval": 1
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format-time": "{H}:{m}",
    "format": "| {icon} {time}",
    "format-charging": "¾░éä {capacity}%",
    "format-plugged": "¾░Üź {capacity}%",
    "format-icons": [
      "¾░éÄe",
      "¾░ü║E",
      "¾░ü╗ŌģĢ",
      "¾░ü╝Ōģō",
      "¾░üĮŌģ¢",
      "¾░üŠ┬Į",
      "¾░ü┐ŌģŚ",
      "¾░éĆŌģś",
      "¾░éüŌģś",
      "¾░ééf",
      "¾░ü╣F"
    ]
  },
  "network": {
    "format-wifi": "¾░¢® {signalStrength}%",
    "format-ethernet": "¾░łĆ {ifname}",
    "format-linked": "¾░łĆ {ifname} (No IP)",
    "format-disconnected": "¾░¢¬ Disconnected",
    "tooltip-format": "¾░¢® {essid} : {ifname}: {ipaddr}",
    "on-click": "alacritty -e nmtui"
  },
  "bluetooth": {
    "format": "’Ŗö",
    "format-connected": "’Ŗö {device_alias}",
    "format-connected-battery": "’Ŗö {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "alacritty -e bluetuith"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "¾░é░ {volume}%",
    "format-bluetooth-muted": "¾░é▓ {icon}",
    "format-muted": "¾░Ø¤",
    "format-icons": {
      "headphone": "¾░ŗŗ",
      "hands-free": "¾░ź░",
      "headset": "¾░ŗÄ",
      "phone": "¾░Å▓",
      "portable": "¾░äØ",
      "car": "¾░äŗ",
      "default": [
        "¾░Ģ┐",
        "¾░¢Ć",
        "¾░ĢŠ"
      ]
    },
    "on-click": "alacritty -e wiremix",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
  },
  "custom/claude": {
    "format": "{}",
    "interval": 300,
    "exec": "claude-statusbar --plan max20 2>/dev/null || \"${HOME}/.claude/scripts/claude-ai-usage.sh\" 2>/dev/null || echo '¾▒Ö║ --'",
    "tooltip": true,
    "on-click": "alacritty -e bash -c 'claude-statusbar --plan max20; read'"
  },
  "custom/claude-usage": {
    "exec": "$HOME/scripts/claude-oauth-usage.sh --waybar",
    "return-type": "json",
    "interval": 120,
    "on-click": "$HOME/scripts/claude-oauth-usage.sh --refresh --waybar",
    "format": "{}",
    "tooltip": true
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "<span foreground='white'>¾░éÜ<sup></sup></span>",
      "none": "¾░é£",
      "dnd-notification": "<span foreground='white'>¾░éø<sup></sup></span>",
      "dnd-none": "¾░éø",
      "inhibited-notification": "<span foreground='white'>¾░éÜ<sup></sup></span>",
      "inhibited-none": "¾░é£",
      "dnd-inhibited-notification": "<span foreground='white'>¾░éø<sup></sup></span>",
      "dnd-inhibited-none": "¾░éø"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "¾░ā×",
      "¾░ā¤",
      "¾░āĀ"
    ],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  }
}
