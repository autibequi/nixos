{
	"layer": "top",
	"position": "bottom",
	"height": 24,
	"spacing": 0,
	"margin": "3px 5px 3px",
	"modules-left": [
		"idle_inhibitor",
		// "custom/vennon",
		"hyprland/workspaces",
		"hyprland/workspaces#special",
		"mpris",
		"custom/cliptoast"
		// "hyprland/window"
	],
	"modules-center": [
		"custom/screenrecord",
		"custom/swaync",
		"custom/chicote",
		"clock",
		"battery"
	],
	"modules-right": [
		"custom/claude-usage",
		"group/system-controls",
		"tray",
		"bluetooth"
	],
	"group/system-controls": {
		"orientation": "horizontal",
		"modules": [
			"pulseaudio",
			"backlight",
			"custom/ddcutil-brightness",
			"network"
		]
	},
	"tray": {
		"icon-size": 14,
		"spacing": 2
	},
	"custom/cliptoast": {
		"exec": "cat /tmp/waybar-cliptoast.json 2>/dev/null || echo '{\"text\":\"\"}'",
		"return-type": "json",
		"interval": "once",
		"signal": 13,
		"format": "{}"
	},
	"custom/screenrecord": {
		"exec": "[ -f /tmp/screenrecord.pid ] && echo '{\"text\":\"¾░æŖ REC\",\"tooltip\":\"Recording... click to stop\",\"class\":\"active\"}' || echo '{\"text\":\"\",\"tooltip\":\"\",\"class\":\"\"}'",
		"return-type": "json",
		"interval": 2,
		"signal": 9,
		"format": "{}",
		"on-click": "screenrecord-toggle"
	},
	"custom/chicote": {
		"exec": "pgrep -x chicote >/dev/null && echo '{\"text\":\"­¤źü\",\"class\":\"active\"}' || echo '{\"text\":\"\",\"class\":\"\"}'",
		"return-type": "json",
		"interval": 2,
		"signal": 12,
		"format": "{}",
		"escape": false,
		"on-click": "$HOME/.config/hypr/chicote-toggle.sh"
	},
	"custom/special-workspaces": {
		"exec": "cat /tmp/waybar-specials.json 2>/dev/null || echo '{\"text\":\"\",\"class\":\"empty\"}'",
		"return-type": "json",
		"interval": 30,
		"signal": 11,
		"format": "{}",
		"escape": false,
		"tooltip": true,
		"on-click": "hyprctl dispatch togglespecialworkspace"
	},
	"group/tray-expander": {
		"orientation": "horizontal",
		"drawer": {
			"transition-duration": 300,
			"children-class": "tray-drawer",
			"transition-left-to-right": false
		},
		"modules": [
			"custom/tray-toggle",
			"tray"
		]
	},
	"custom/tray-toggle": {
		"format": "",
		"tooltip-format": "Expand tray",
		"interval": "once"
	},
	"power-profiles-daemon": {
		"format": "{icon}",
		"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
		"tooltip": true,
		"format-icons": {
			"default": "’ü¼",
			"performance": "’ā¦",
			"balanced": "’ēÄ",
			"power-saver": "’ü¼"
		}
	},
	"hyprland/window": {
		"format": "{}",
		"max-length": 50,
		"rewrite": {
			"Claude\\[(.+?)\\]:.*": "¾▒Ö║ $1",
			"(.*) ŌĆö Claude.*": "¾▒Ö║ $1",
			"[Ō£│ŌĀÉ] (.+)": "¾▒Ö║ $1"
		}
	},
	"hyprland/workspaces": {
		"interval": 1,
		"disable-scroll": true,
		"all-outputs": false,
		"move-to-monitor": true,
		"show-special": false,
		"persistent-workspaces": {},
		"format": "{icon}{windows}</span>",
		"on-click": "activate",
		"tooltip": true,
		"tooltip-format": "{name}",
		"window-rewrite-default": "’üÖ",
		"escape": false,
		"format-icons": {
			"f1": "<span foreground='#b05450'>F1: ",
			"f2": "<span foreground='#a87240'>F2: ",
			"f3": "<span foreground='#9a8838'>F3: ",
			"f4": "<span foreground='#429960'>F4: ",
			"f5": "<span foreground='#369088'>F5: ",
			"f6": "<span foreground='#4070a8'>F6: ",
			"f7": "<span foreground='#7058a0'>F7: ",
			"f8": "<span foreground='#8040a8'>F8: ",
			"f9": "<span foreground='#8040a8'>F9: ",
			"f10": "<span foreground='#8040a8'>F10: ",
			"bleh": "<span>~: ",
			"1": "<span>1:",
			"2": "<span>2:",
			"3": "<span>3",
			"4": "<span>4:",
			"5": "<span>5:",
			"6": "<span>6:",
			"7": "<span>7:",
			"8": "<span>8:",
			"9": "<span>9:",
			"10": "<span>10:",
			"gemini": "<span>gemini: ",
			"default": "<span>"
		},
		"workspace-taskbar": {
			"format": "{icon} {title}",
			"format-icons": {
				"default": "’üÖ "
			},
			"tooltip": true
		},
		"window-rewrite": {
			"title<(.*[$%#] *)?([hb]|nv)top.*>": "¾░ōģ",
			"title<(.* - )?(.[0-9]+. )?YouTube Music.*>": "’ģ¬",
			"title<(.*)(books - Obsidian)(.*)>": "’ĆŁ",
			"class<(.*)(chat)(.*)>": "¾░ŹĪ",
			"class<(Alacritty|ghostty)> title<(.*)(Ō£│ )(.*)>": "¾▒Ö║",
			"class<(Alacritty|ghostty)> title<\\xe2[\\xa0-\\xa3][\\x80-\\xbf] >": "¾▒Ö║",
			"class<(Alacritty|ghostty)> title<^(n?vim)>": "¾░ĢĘ",
			"class<(Alacritty|ghostty)> title<^(node|npm|pnpm|bun)>": "¾░ÄÖ",
			"class<(Alacritty|ghostty)> title<^(go|make)>": "¾░¤ō",
			"class<(Alacritty|ghostty)> title<^(git|tig|lazygit)>": "¾░Ŗó",
			"class<(Alacritty|ghostty)> title<^(docker|podman)>": "¾░Ī©",
			"class<(Alacritty|ghostty)> title<^(ssh|mosh)>": "¾░īś",
			"class<(Alacritty|ghostty)> title<^(python|python3)>": "¾░īĀ",
			"class<(.*)(chrome-claude)(.*)>": "Ō£╗",
			"title<(.*)(Gemini)(.*)>": "¾░╝Ö",
			"title<(.*)(JIRA)(.*)>": "¾░īā",
			"title<(.*)(Meet)(.*)>": "¾░ö©",
			"firefox": "’ē®",
			"vivaldi": "’ē®",
			"app.zen_browser.zen": "’ē®",
			"zen": "’ē®",
			"chrome": "’ē©",
			"chromium": "’ē©",
			"dbeaver": "­¤”½",
			"code": "¾░©×",
			"cursor": "¾░©×",
			"obsidian": "’ÆŖ",
			"Alacritty": "¾░åŹ",
			"ghostty": "¾░åŹ",
			"org.gnome.Nautilus": "’ü╝",
			"zed": "­ØŚŁ",
			"stremio": "­¤Ź┐",
			"insomnia": "’łČ",
			"yaak-app": "¾░åÜ",
			"class<^steam_app_.*>": "¾░«»",
			"title<.*Steam.*>": "’åČ"
		}
	},
	"hyprland/workspaces#special": {
		"disable-scroll": true,
		"all-outputs": false,
		"move-to-monitor": true,
		"show-special": true,
		"persistent-workspaces": {},
		"on-click": "activate",
		"format": "{icon}{windows}</span>",
		"tooltip": true,
		"tooltip-format": "{name}",
		"window-rewrite-default": "",
		"escape": false,
		"format-icons": {
			"f1": "<span>F1:",
			"f2": "<span>F2:",
			"f3": "<span>F3:",
			"f4": "<span>F4:",
			"f5": "<span>F5:",
			"f6": "<span>F6:",
			"f7": "<span>F7:",
			"f8": "<span>F8:",
			"f9": "<span>F9:",
			"f10": "<span>F10:",
			"bleh": "<span>~:",
			"gemini": "<span>gemini:",
			"1": "<span>",
			"2": "<span>",
			"3": "<span>",
			"4": "<span>",
			"5": "<span>",
			"6": "<span>",
			"7": "<span>",
			"8": "<span>",
			"9": "<span>",
			"10": "<span>",
			"default": "<span>"
		},
		"window-rewrite": {
			"title<(.*[$%#] *)?([hb]|nv)top.*>": "¾░ōģ",
			"title<(.* - )?(.[0-9]+. )?YouTube Music.*>": "",
			"title<.* - Obsidian>": "’ĆŁ",
			"class<(.*)(chat)(.*)>": "¾░ŹĪ",
			"class<(Alacritty|ghostty)> title<(.*)(Ō£│ )(.*)>": "¾▒Ö║",
			"class<(Alacritty|ghostty)> title<\\xe2[\\xa0-\\xa3][\\x80-\\xbf] >": "¾▒Ö║",
			"class<(Alacritty|ghostty)> title<^(n?vim)>": "¾░ĢĘ",
			"class<(Alacritty|ghostty)> title<^(node|npm|pnpm|bun)>": "¾░ÄÖ",
			"class<(Alacritty|ghostty)> title<^(go|make)>": "¾░¤ō",
			"class<(Alacritty|ghostty)> title<^(git|tig|lazygit)>": "¾░Ŗó",
			"class<(Alacritty|ghostty)> title<^(docker|podman)>": "¾░Ī©",
			"class<(Alacritty|ghostty)> title<^(ssh|mosh)>": "¾░īś",
			"class<(Alacritty|ghostty)> title<^(python|python3)>": "¾░īĀ",
			"class<(.*)(chrome-claude)(.*)>": "Ō£╗",
			"title<(.*)(Gemini)(.*)>": "¾░╝Ö",
			"title<(.*)(JIRA)(.*)>": "¾░īā",
			"title<(.*)(Meet)(.*)>": "¾░ö©",
			"firefox": "’ē®",
			"vivaldi": "’ē®",
			"zen": "’ē®",
			"chrome": "’ē©",
			"class<[Oo]bsidian>": "’ĆŁ",
			"Alacritty": "¾░åŹ",
			"ghostty": "¾░åŹ",
			"zed": "¾░░Č"
		}
	},
	"mpris": {
		"format": "{player_icon} {title} - {artist}",
		"format-paused": "{status_icon} CALA A BOCA!",
		"max-length": 30,
		"tooltip-format": "{title} | {artist}",
		"player-icons": {
			"default": "Ō¢Č",
			"firefox": "’ē®",
			"chrome": "’ē©",
		},
		"status-icons": {
			"paused": "ŌÅĖ"
		},
		"on-click": "playerctl play-pause",
		"on-click-right": "playerctl next",
		"on-scroll-up": "playerctl next",
		"on-scroll-down": "playerctl previous"
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "¾░ģČ",
			"deactivated": "¾░ģĘ"
		},
		"tooltip": true
	},
	"clock": {
		"format": "¾░źö {:%H:%M}",
		"interval": 60,
		"format-alt": "¾░źö {:%H:%M}  ¾░āŁ {:%d/%m}",
		"tooltip-format": "{:%A, %d %B ┬Ę %H:%M}",
		"tooltip": true,
		"on-click": "qs ipc call clock toggle"
	},
	"cpu": {
		"format": "¾░Źø {usage}%",
		"tooltip": true,
		"interval": 10
	},
	"memory": {
		"format": "¾░śÜ {}%",
		"interval": 5
	},
	"battery": {
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{m}",
		"format": "{icon}{capacity}% {time}",
		"format-charging": "¾░éä {capacity}%",
		"format-plugged": "¾░Üź {capacity}%",
		"format-icons": [
			"¾░éÄ",
			"¾░ü║",
			"¾░ü╗",
			"¾░ü╝",
			"¾░üĮ",
			"¾░üŠ",
			"¾░ü┐",
			"¾░éĆ",
			"¾░éü",
			"¾░éé",
			"¾░ü╣"
		]
	},
	"network": {
		"format": "¾░ż½",
		"format-wifi": "¾░¢® {signalStrength}%",
		"format-ethernet": "¾░łĆ {ifname}",
		"format-linked": "¾░łĆ {ifname} (No IP)",
		"format-disconnected": "¾░¢¬ Disconnected",
		"format-disabled": "¾░ż« Wi-Fi off",
		"tooltip-format": "¾░¢® {essid} : {ifname}: {ipaddr}",
		"tooltip-format-disconnected": "Sem conex├Żo ŌĆö clique para gerenciar",
		"tooltip-format-disabled": "Wi-Fi desligado ŌĆö clique para gerenciar",
		"on-click": "$HOME/.config/hypr/walker-launch.sh --theme neon --provider menus:wifi",
		"on-click-right": "alacritty -e nmtui"
	},
	"bluetooth": {
		"format": "’Ŗö",
		"format-connected": "’Ŗö {device_alias}",
		"format-connected-battery": "’Ŗö {device_alias} {device_battery_percentage}%",
		"tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
		"on-click": "$HOME/.config/hypr/walker-launch.sh --theme neon --provider bluetooth",
		"on-click-right": "alacritty -e bluetuith"
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-bluetooth": "¾░é░ {volume}%",
		"format-bluetooth-muted": "¾░é▓ {icon}",
		"format-muted": "¾░Ø¤",
		"format-icons": {
			"headphone": "¾░ŗŗ",
			"hands-free": "¾░ź░",
			"headset": "¾░ŗÄ",
			"phone": "¾░Å▓",
			"portable": "¾░äØ",
			"car": "¾░äŗ",
			"default": [
				"¾░Ģ┐",
				"¾░¢Ć",
				"¾░ĢŠ"
			]
		},
		"on-click": "$HOME/.config/hypr/walker-launch.sh --provider wireplumber",
		"on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"on-click-middle": "alacritty -e wiremix",
		"on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
		"on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
	},
	"custom/claude-usage": {
		"exec": "yaa claude usage --waybar",
		"return-type": "json",
		"interval": 60,
		"signal": 8,
		"on-click": "xdg-open https://claude.ai/settings/usage",
		"on-click-right": "yaa claude usage --refresh --waybar; pkill -RTMIN+8 waybar",
		"format": "{}",
		"tooltip": true,
		"escape": false,
		"markup": "pango"
	},
	"custom/obsidian-sync": {
		"exec": "$HOME/.config/waybar/obsidian-sync-status.sh",
		"return-type": "json",
		"interval": 30,
		"format": "{}",
		"tooltip": true,
		"escape": false,
		"on-click": "alacritty -e bash -c '$HOME/.config/waybar/obsidian-sync-panel.sh'",
		"on-click-right": "alacritty -e journalctl -u obsidian-sync -f"
	},
	"custom/cpu-bar": {
		"exec": "$HOME/.config/waybar/waybar-resource-bar.sh cpu",
		"return-type": "json",
		"interval": 2,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},
	"custom/gpu-bar": {
		"exec": "$HOME/.config/waybar/waybar-resource-bar.sh gpu",
		"return-type": "json",
		"interval": 2,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},
	"custom/ram-bar": {
		"exec": "$HOME/.config/waybar/waybar-resource-bar.sh memory",
		"return-type": "json",
		"interval": 2,
		"format": "{}",
		"tooltip": true,
		"escape": false
	},
	"custom/swaync": {
		"tooltip": false,
		"format": "{icon} {text}",
		"format-icons": {
			"notification": "<span foreground='white'>¾░éÜ<sup></sup></span>",
			"none": "¾░é£",
			"dnd-notification": "<span foreground='white'>¾░éø<sup></sup></span>",
			"dnd-none": "¾░éø",
			"inhibited-notification": "<span foreground='white'>¾░éÜ<sup></sup></span>",
			"inhibited-none": "¾░é£",
			"dnd-inhibited-notification": "<span foreground='white'>¾░éø<sup></sup></span>",
			"dnd-inhibited-none": "¾░éø"
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	},
	"custom/ddcutil-brightness": {
		"exec": "$HOME/.config/waybar/ddcutil-brightness.sh",
		"return-type": "json",
		"interval": 30,
		"signal": 10,
		"format": "{}",
		"tooltip": true,
		"on-scroll-up": "$HOME/.config/waybar/ddcutil-scroll.sh up && pkill -RTMIN+10 waybar",
		"on-scroll-down": "$HOME/.config/waybar/ddcutil-scroll.sh down && pkill -RTMIN+10 waybar"
	},
	"backlight": {
		"format": "{icon} {percent}%",
		"format-icons": [
			"¾░ā×",
			"¾░ā¤",
			"¾░āĀ"
		],
		"on-scroll-up": "brightnessctl set +5%",
		"on-scroll-down": "brightnessctl set 5%-"
	}
}
