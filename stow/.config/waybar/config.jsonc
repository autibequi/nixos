{
  "layer": "bottom",
  "position": "bottom",
  "spacing": 0,
  "margin": 0,
  "modules-left": [
    "idle_inhibitor",
    "hyprland/workspaces"
    // "hyprland/window"
  ],
  "modules-center": [
    "custom/swaync",
    "clock",
    "battery"
  ],
  "modules-right": [
    "custom/claude",
    "mpris",
    "pulseaudio",
    "backlight",
    "network",
    "tray",
    "bluetooth"
  ],
  "tray": {
    "icon-size": 14,
    "spacing": 5,
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "пҒ¬",
      "performance": "пғ§",
      "balanced": "пүҺ",
      "power-saver": "пҒ¬"
    }
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "rewrite": {
      "Claude\\[(.+?)\\]:.*": "уұҷә $1",
      "(.*) вҖ” Claude.*": "уұҷә $1"
    }
  },
  "hyprland/workspaces": {
    "interval": 1,
    "disable-scroll": true,
    "all-outputs": false,
    "show-special": true,
    "format": "{icon}:{windows}",
    "tooltip": true,
    "tooltip-format": "{name}",
    "window-rewrite-default": "пҒҷ",
    "format-icons": {
      "f8": "f8.settings",
      "bleh": "~.claudinho",
      "1": "1.code",
      "2": "2.test",
      "3": "3.web",
      // "f1": "К•в– бҙҘв– К”",
      // "f2": "К•в– бҙҘв– К”",
      // "f3": "К•в– бҙҘв– К”",
      // "f4": "К•в– бҙҘв– К”"
    },
    "workspace-taskbar": {
      "format": "{icon} {title}",
      "format-icons": {
        "default": "пҒҷ "
      },
      "tooltip": true
    },
    "window-rewrite": {
      "title<(.*[$%#] *)?([hb]|nv)top.*>": "btop",
      "title<(.* - )?(.[0-9]+. )?YouTube Music.*>": "п…Ә",
      "title<(.*)(books - Obsidian)(.*)>": "пҖӯ",
      "class<(.*)(chat)(.*)>": "у°ҚЎ",
      "class<(Alacritty|ghostty)> title<(.*)(вңі Claude)(.*)>": "уұҷә",
      "class<(.*)(chrome-claude)(.*)>": "вң»",
      "title<(.*)(Gemini)(.*)>": "у°јҷ",
      "title<(.*)(JIRA)(.*)>": "у°Ңғ",
      "title<(.*)(Meet)(.*)>": "пӮ•",
      "firefox": "пү©",
      "vivaldi": "пү©",
      "app.zen_browser.zen": "пү©",
      "zen": "пү©",
      "chrome": "пүЁ",
      "dbeaver": "рҹҰ«",
      "code": "у°Ёһ",
      "cursor": "у°Ёһ",
      "obsidian": "п’Ҡ",
      "Alacritty": "у°ҶҚ",
      "ghostty": "у°ҶҚ",
      "org.gnome.Nautilus": "пҒј",
      "zed": "у°°¶",
      "stremio": "рҹҚҝ",
      "insomnia": "пҲ¶",
      "yaak-app": "у°Ҷҡ",
      "class<^steam_app_.*>": "у°®Ҝ",
      "title<.*Steam.*>": "пҶ¶"
    }
  },
  "mpris": {
    "format": "{player_icon} {title} - {artist}",
    "format-paused": "{status_icon} CALADO, MORTAL!",
    "max-length": 30,
    "tooltip-format": "{title} | {artist}",
    "player-icons": {
      "default": "в–¶",
      "firefox": "пү©",
      "chrome": "пүЁ",
    },
    "status-icons": {
      "paused": "вҸё"
    },
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "у°ҲҲ ",
      "deactivated": "у°Ҳү "
    },
    "tooltip": true
  },
  "clock": {
    "format": "у°Ҙ” {:%H:%M:%S}",
    "interval": 1,
    "format-alt": "у°ғ® {:%Y-%m-%d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#d3c6aa'><b>{}</b></span>",
        "days": "<span color='#e67e80'>{}</span>",
        "weeks": "<span color='#a7c080'><b>W{}</b></span>",
        "weekdays": "<span color='#7fbbb3'><b>{}</b></span>",
        "today": "<span color='#dbbc7f'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "cpu": {
    "format": "у°Қӣ {usage}%",
    "tooltip": true,
    "interval": 10
  },
  "memory": {
    "format": "у°ҳҡ {}%",
    "interval": 1
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format-time": "{H}:{m}",
    "format": "| {icon} {time}",
    "format-charging": "у°Ӯ„ {capacity}%",
    "format-plugged": "у°ҡҘ {capacity}%",
    "format-icons": [
      "у°ӮҺe",
      "у°ҒәE",
      "у°Ғ»в…•",
      "у°Ғјв…“",
      "у°ҒҪв…–",
      "у°ҒҫВҪ",
      "у°Ғҝв…—",
      "у°ӮҖв…ҳ",
      "у°ӮҒв…ҳ",
      "у°ӮӮf",
      "у°Ғ№F"
    ]
  },
  "network": {
    "format-wifi": "у°–© {signalStrength}%",
    "format-ethernet": "у°ҲҖ {ifname}",
    "format-linked": "у°ҲҖ {ifname} (No IP)",
    "format-disconnected": "у°–Ә Disconnected",
    "tooltip-format": "у°–© {essid} : {ifname}: {ipaddr}",
    "on-click": "alacritty -e nmtui"
  },
  "bluetooth": {
    "format": "пҠ”",
    "format-connected": "пҠ” {device_alias}",
    "format-connected-battery": "пҠ” {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "alacritty -e bluetuith"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "у°Ӯ° {volume}%",
    "format-bluetooth-muted": "у°ӮІ {icon}",
    "format-muted": "у°қҹ",
    "format-icons": {
      "headphone": "у°ӢӢ",
      "hands-free": "у°Ҙ°",
      "headset": "у°ӢҺ",
      "phone": "у°ҸІ",
      "portable": "у°„қ",
      "car": "у°„Ӣ",
      "default": [
        "у°•ҝ",
        "у°–Җ",
        "у°•ҫ"
      ]
    },
    "on-click": "alacritty -e wiremix",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
  },
  "custom/claude": {
    "format": "{}",
    "interval": 300,
    "exec": "claude-statusbar --plan max20 2>/dev/null || echo 'уұҷә --'",
    "tooltip": true,
    "on-click": "alacritty -e bash -c 'claude-statusbar --plan max20; read'"
  },
  "custom/swaync": {
    "tooltip": false,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "<span foreground='white'>у°Ӯҡ<sup></sup></span>",
      "none": "у°Ӯң",
      "dnd-notification": "<span foreground='white'>у°Ӯӣ<sup></sup></span>",
      "dnd-none": "у°Ӯӣ",
      "inhibited-notification": "<span foreground='white'>у°Ӯҡ<sup></sup></span>",
      "inhibited-none": "у°Ӯң",
      "dnd-inhibited-notification": "<span foreground='white'>у°Ӯӣ<sup></sup></span>",
      "dnd-inhibited-none": "у°Ӯӣ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "у°ғһ",
      "у°ғҹ",
      "у°ғ "
    ],
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  }
}
