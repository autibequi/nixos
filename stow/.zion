# ~/.zion — Canal de comunicação rápida
# Montado em todos os containers: ~/.zion (zion) e /.zion (app containers)
# Lido no boot de cada sessão via session-start.sh → ---ZION--- block
# Formato: KEY=value (linhas com # são ignoradas)

# ── Mensagem para o agente ─────────────────────────────────────
# Lida no próximo boot. Limpe após usar.
MESSAGE=

# ── Context / projeto ativo ────────────────────────────────────
# PROJECT=
# CONTEXT=

# ── Notas rápidas ──────────────────────────────────────────────
# NOTE=
