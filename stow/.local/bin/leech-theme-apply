#!/usr/bin/env bash
# leech-theme-apply — reads colors.toml, generates waybar/hyprland color configs
# Usage: leech-theme-apply [dark|light]
set -euo pipefail

COLORS_DIR="$HOME/.config/leech"
STAGING_DIR="/tmp/leech-theme-staging"
VARIANT="${1:-dark}"

if [ "$VARIANT" = "light" ]; then
    COLORS_FILE="$COLORS_DIR/colors-light.toml"
else
    COLORS_FILE="$COLORS_DIR/colors.toml"
fi

if [ ! -f "$COLORS_FILE" ]; then
    echo "Colors file not found: $COLORS_FILE" >&2
    exit 1
fi

# Simple TOML parser: _get section.key → value (strips quotes)
_get() {
    local section key
    section="${1%%.*}"
    key="${1#*.}"
    awk -v s="[$section]" -v k="$key" '
        $0 == s { found=1; next }
        /^\[/ { found=0 }
        found && $1 == k {
            sub(/^[^=]*=[ \t]*/, "")
            gsub(/^"|"$/, "")
            print
            exit
        }
    ' "$COLORS_FILE"
}

# ── Generate waybar colors.css ─────────────────────────────
generate_waybar() {
    local out="$STAGING_DIR/colors.css"
    cat > "$out" << EOF
/* Generated by leech-theme-apply — do not edit manually */
@define-color color-black $(_get palette.bg);
@define-color color-white $(_get palette.fg);
@define-color color-red $(_get palette.red);
@define-color color-yellow $(_get palette.yellow);
@define-color color-green $(_get palette.green);
@define-color color-blue $(_get palette.blue);
@define-color color-orange $(_get palette.orange);

@define-color main-bg @color-black;
@define-color main-text @color-white;

@define-color ws-text @main-text;
@define-color ws-active-bg @color-white;
@define-color ws-active-text @color-black;
@define-color ws-urgent-bg @color-black;
@define-color ws-urgent-text @color-red;
@define-color ws-special-text @color-yellow;
@define-color ws-special-active-bg @color-black;
@define-color ws-special-active-text @color-green;
@define-color ws-special-hover-text @color-green;

@define-color mpris-text @color-white;
@define-color clock-text @color-white;
@define-color battery-text @color-white;
@define-color battery-charging-text @color-white;
@define-color battery-warning-text @color-white;
@define-color battery-critical-text @color-white;
@define-color network-text @color-white;
@define-color network-disconnected-text @color-white;
@define-color audio-text @color-white;
@define-color audio-muted-text @color-white;
@define-color backlight-text @color-white;
@define-color idle-inhibitor-text @main-text;
@define-color idle-inhibitor-active-text @color-white;
EOF
}

# ── Generate hyprland colors ───────────────────────────────
generate_hyprland() {
    local out="$STAGING_DIR/generated-colors.conf"
    cat > "$out" << EOF
# Generated by leech-theme-apply — do not edit manually
general {
    col.active_border = $(_get border.active)
}
EOF
}

# ── Apply ──────────────────────────────────────────────────
main() {
    mkdir -p "$STAGING_DIR"

    generate_waybar
    generate_hyprland

    # Atomic copy to final locations
    cp "$STAGING_DIR/colors.css" "$HOME/.config/waybar/colors.css"
    cp "$STAGING_DIR/generated-colors.conf" "$HOME/.config/hypr/generated-colors.conf"

    # Reload waybar styles (SIGUSR2 = reload style only)
    pkill -SIGUSR2 waybar 2>/dev/null || true

    # Clean staging
    rm -rf "$STAGING_DIR"
}

main
