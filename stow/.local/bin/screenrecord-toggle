#!/usr/bin/env bash
# screenrecord-toggle — start/stop wf-recorder, signal waybar
set -euo pipefail

PIDFILE="/tmp/screenrecord.pid"
OUTDIR="$HOME/Videos"

if [ -f "$PIDFILE" ]; then
    kill "$(cat "$PIDFILE")" 2>/dev/null || true
    rm -f "$PIDFILE"
    pkill -RTMIN+9 waybar 2>/dev/null || true
    notify-send -t 1000 "Recording stopped"
else
    mkdir -p "$OUTDIR"
    monitor=$(hyprctl monitors -j | jq -r '.[] | select(.focused) | .name')
    wf-recorder -o "$monitor" -f "$OUTDIR/recording_$(date +%Y%m%d_%H%M%S).mp4" &
    echo $! > "$PIDFILE"
    pkill -RTMIN+9 waybar 2>/dev/null || true
    notify-send -t 1000 "Recording started"
fi
