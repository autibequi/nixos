#!/usr/bin/env bash
# leech-menu — Omarchy-inspired hierarchical menu with app icons
set -euo pipefail

HYPRUTILS="$HOME/.config/hypr/hyprutils.sh"

# Helper: pipe options to rofi dmenu (for submenus, no icons needed)
_select() {
    printf '%s\n' "$@" | rofi -dmenu -i -p "" \
        -theme-str 'window { width: 300px; }' \
        -theme-str 'listview { lines: 8; }' \
        -theme-str '* { font: "JetBrainsMono Nerd Font 13"; }'
}

# ── Main Menu (rofi drun + custom entries with icons) ──────
menu_main() {
    # Use rofi modi combo: a custom script for categories + drun for apps
    local choice
    choice=$(rofi -show combi \
        -combi-modi "drun,Categories:leech-menu-categories" \
        -modi "combi" \
        -show-icons \
        -icon-theme "Papirus" \
        -display-combi "Menu" \
    ) || return 0

    # If rofi launched a drun app, it already ran it — nothing to do.
    # If it returned a category name, we handle it here.
    case "$choice" in
        *Capture)  menu_capture ;;
        *Toggle)   menu_toggle ;;
        *Style)    menu_style ;;
        *Leech)    menu_leech ;;
        *System)   menu_system ;;
    esac
}

# ── Capture ────────────────────────────────────────────────
menu_capture() {
    local choice
    choice=$(_select \
        "󰹑 Screenshot (region)" \
        "󰹑 Screenshot (full + crop)" \
        " Screenshot (annotate)" \
        " OCR Region" \
        " Color Picker" \
        " Clipboard History" \
        "← Back"
    ) || return 0

    case "$choice" in
        *region*)       "$HYPRUTILS" print_screen_to_clipboard ;;
        *crop*)         "$HYPRUTILS" print_screen_full_then_crop ;;
        *annotate*)     "$HYPRUTILS" print_screen_with_notes ;;
        *OCR*)          "$HYPRUTILS" tesseract_region ;;
        *Color*)        hyprpicker --autocopy --lowercase-hex ;;
        *Clipboard*)    "$HYPRUTILS" clipboard_history ;;
        *Back)          menu_main ;;
    esac
}

# ── Toggle ─────────────────────────────────────────────────
menu_toggle() {
    local choice
    choice=$(_select \
        " Theme (dark/light)" \
        " Waybar" \
        "󰂛 DND (Notifications)" \
        "󰑊 Screenrecord" \
        "← Back"
    ) || return 0

    case "$choice" in
        *Theme*)        "$HYPRUTILS" toggle_theme ;;
        *Waybar*)       toggle_waybar ;;
        *DND*)          swaync-client -d -sw ;;
        *Screenrecord*) screenrecord-toggle 2>/dev/null || notify-send "screenrecord-toggle not found" ;;
        *Back)          menu_main ;;
    esac
}

toggle_waybar() {
    if pgrep -x waybar >/dev/null; then
        pkill waybar
        notify-send -t 500 "Waybar hidden"
    else
        uwsm app -- waybar &
        notify-send -t 500 "Waybar shown"
    fi
}

# ── Style ──────────────────────────────────────────────────
menu_style() {
    local choice
    choice=$(_select \
        " Theme (dark/light)" \
        "󰸉 Wallpaper" \
        "← Back"
    ) || return 0

    case "$choice" in
        *Theme*)      "$HYPRUTILS" toggle_theme ;;
        *Wallpaper*)  menu_wallpaper ;;
        *Back)        menu_main ;;
    esac
}

menu_wallpaper() {
    local dir="$HOME/assets/wallpapers"
    if [ ! -d "$dir" ]; then
        notify-send "No wallpapers directory" "$dir"
        return
    fi

    local choice
    choice=$(find "$dir" -type f \( -name '*.jpg' -o -name '*.png' -o -name '*.webp' \) -printf '%f\n' | sort | rofi -dmenu -i -p "Wallpaper") || return 0
    [ -z "$choice" ] && return

    swww img "$dir/$choice" --transition-type fade --transition-fps 60 --transition-duration 0.3
    notify-send -t 1000 "Wallpaper" "$choice"
}

# ── Leech ──────────────────────────────────────────────────
menu_leech() {
    local choice
    choice=$(_select \
        "󱙺 Claude Usage" \
        " Agents" \
        "󰡨 Container Shell" \
        "← Back"
    ) || return 0

    case "$choice" in
        *Claude*)     alacritty -e bash -c 'leech claude usage 2>/dev/null || echo "leech not available"; read -p "Press enter..."' ;;
        *Agents*)     alacritty -e bash -c 'leech agents 2>/dev/null || echo "leech not available"; read -p "Press enter..."' ;;
        *Container*)  alacritty -e bash -c 'leech shell 2>/dev/null || echo "leech not available"; exec bash -i' ;;
        *Back)        menu_main ;;
    esac
}

# ── System ─────────────────────────────────────────────────
menu_system() {
    local choice
    choice=$(_select \
        " Lock" \
        "󰤄 Suspend" \
        " Reload Hyprland" \
        " Restart" \
        "⏻ Shutdown" \
        "← Back"
    ) || return 0

    case "$choice" in
        *Lock*)       hyprlock ;;
        *Suspend*)    systemctl suspend ;;
        *Reload*)     "$HYPRUTILS" hypr_reload ;;
        *Restart*)    systemctl reboot ;;
        *Shutdown*)   systemctl poweroff ;;
        *Back)        menu_main ;;
    esac
}

# ── Entry Point ────────────────────────────────────────────
if [ $# -gt 0 ]; then
    case "${1,,}" in
        capture)    menu_capture ;;
        toggle)     menu_toggle ;;
        style)      menu_style ;;
        leech)      menu_leech ;;
        system)     menu_system ;;
        wallpaper)  menu_wallpaper ;;
        *)          menu_main ;;
    esac
else
    menu_main
fi
