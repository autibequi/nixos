#!/usr/bin/env bash
# whisper-ctl — send commands to the whisper-ptt daemon via Unix socket
# Usage: whisper-ctl start|stop|status|quit

SOCKET="/tmp/whisper-ptt.sock"

if [[ $# -lt 1 ]]; then
    echo "Usage: whisper-ctl <start|stop|status|quit>"
    exit 1
fi

if [[ ! -S "$SOCKET" ]]; then
    notify-send -a "Whisper PTT" "Whisper PTT" "Daemon nao esta rodando" 2>/dev/null
    echo "error: daemon not running (socket not found)"
    exit 1
fi

echo "$1" | socat - UNIX-CONNECT:"$SOCKET"
